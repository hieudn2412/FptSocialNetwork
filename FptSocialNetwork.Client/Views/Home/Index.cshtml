@{
    ViewData["Title"] = "FPT Social Home";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --bg-page: #141516;
            --bg-topbar: #202123;
            --bg-card: #212326;
            --bg-soft: #34373b;
            --text-main: #e9eaec;
            --text-muted: #b6b9bf;
            --brand-500: #f37021;
            --brand-600: #e45f10;
            --brand-700: #c94f0c;
            --brand-soft: rgba(243, 112, 33, 0.16);
            --success: #31a24c;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: "Segoe UI", Arial, Helvetica, sans-serif;
            background: radial-gradient(circle at 20% -20%, #2e2218 0%, var(--bg-page) 42%) fixed;
            color: var(--text-main);
            overflow-x: hidden;
        }

        a { text-decoration: none; color: inherit; }
        ul { list-style: none; }

        .app {
            min-height: 100vh;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 56px;
            background: var(--bg-topbar);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            border-bottom: 1px solid #373a3f;
            backdrop-filter: blur(4px);
        }

        .topbar-left,
        .topbar-center,
        .topbar-right {
            display: flex;
            align-items: center;
        }

        .topbar-left {
            gap: 12px;
            min-width: 320px;
        }

        .logo {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand-500), #ff9a3f);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            box-shadow: 0 8px 18px rgba(243, 112, 33, 0.35);
        }

        .search-box {
            width: 240px;
            height: 40px;
            background: #35383d;
            border-radius: 999px;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 14px;
            color: var(--text-muted);
            border: 1px solid transparent;
        }

        .search-box:focus-within {
            border-color: rgba(243, 112, 33, 0.5);
            box-shadow: 0 0 0 2px rgba(243, 112, 33, 0.12);
        }

        .search-box input {
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-main);
            width: 100%;
            font-size: 15px;
        }

        .topbar-center {
            gap: 8px;
            flex: 1;
            justify-content: center;
        }

        .nav-icon {
            width: 112px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: var(--text-muted);
            font-size: 22px;
            position: relative;
            transition: .2s;
        }

        .nav-icon:hover { background: #31353a; }

        .nav-icon.active {
            color: var(--brand-500);
            background: var(--brand-soft);
        }

        .nav-icon.active::after {
            content: "";
            position: absolute;
            bottom: -4px;
            left: 14px;
            right: 14px;
            height: 3px;
            background: var(--brand-500);
            border-radius: 999px;
        }

        .topbar-right {
            gap: 8px;
            min-width: 180px;
            justify-content: flex-end;
        }

        .circle-btn,
        .profile-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #373a3f;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-main);
            font-size: 18px;
            transition: 0.2s;
        }

        .circle-btn:hover,
        .profile-btn:hover {
            background: #42454b;
        }

        .profile-btn {
            background: #e4e6eb;
            color: #65676b;
            font-size: 20px;
        }

        .layout {
            display: grid;
            grid-template-columns: 320px minmax(500px, 680px) 320px;
            justify-content: space-between;
            gap: 24px;
            padding: 16px;
            max-width: 1600px;
            margin: 0 auto;
        }

        .sidebar, .contacts {
            position: sticky;
            top: 72px;
            height: calc(100vh - 88px);
            overflow-y: auto;
            padding-right: 6px;
        }

        .sidebar::-webkit-scrollbar,
        .contacts::-webkit-scrollbar,
        .feed::-webkit-scrollbar {
            width: 8px;
        }

        .sidebar::-webkit-scrollbar-thumb,
        .contacts::-webkit-scrollbar-thumb,
        .feed::-webkit-scrollbar-thumb {
            background: #4e4f50;
            border-radius: 8px;
        }

        .menu-item,
        .contact-item,
        .group-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: var(--text-main);
            font-weight: 500;
            transition: 0.2s;
        }

        .menu-item:hover,
        .contact-item:hover,
        .group-item:hover {
            background: #2d3034;
        }

        .menu-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .menu-icon.blue { color: #2d88ff; }
        .menu-icon.purple { color: #ff9a3f; }
        .menu-icon.green { color: #45bd62; }
        .menu-icon.orange { color: var(--brand-500); }
        .menu-icon.red { color: #f5533d; }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #d8dadf;
            color: #65676b;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .separator {
            border-top: 1px solid #3a3b3c;
            margin: 8px 0 12px;
        }

        .section-title {
            color: var(--text-muted);
            font-weight: 600;
            font-size: 17px;
            margin: 8px 12px;
        }

        .feed {
            min-height: calc(100vh - 88px);
        }

        .card {
            background: var(--bg-card);
            border-radius: 12px;
            box-shadow: 0 1px 2px rgba(0,0,0,.4);
            margin-bottom: 16px;
            overflow: hidden;
            border: 1px solid #34373b;
        }

        .create-post {
            padding: 12px 16px 10px;
        }

        .create-top {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 12px;
            border-bottom: 1px solid #3a3b3c;
        }

        .post-input {
            flex: 1;
            background: #373a3f;
            border: none;
            outline: none;
            border-radius: 999px;
            color: var(--text-muted);
            padding: 12px 16px;
            font-size: 16px;
        }

        .create-actions {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin-top: 8px;
        }

        .create-action {
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--text-muted);
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .create-action:hover { background: #373a3f; }
        .create-action .fa-video { color: #f3425f; }
        .create-action .fa-image { color: #45bd62; }
        .create-action .fa-face-smile { color: #f7b928; }

        .stories {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding: 0 2px 4px;
        }

        .stories::-webkit-scrollbar { display: none; }

        .story {
            min-width: 112px;
            height: 200px;
            border-radius: 12px;
            overflow: hidden;
            position: relative;
            background: linear-gradient(180deg, #54565a 0%, #242526 100%);
            border: 1px solid #3a3b3c;
        }

        .story img.bg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .88;
        }

        .story .story-avatar {
            position: absolute;
            top: 12px;
            left: 12px;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: 3px solid var(--brand-500);
            overflow: hidden;
            background: #d8dadf;
        }

        .story .story-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .story .story-name {
            position: absolute;
            bottom: 12px;
            left: 12px;
            right: 12px;
            font-size: 13px;
            font-weight: 600;
            line-height: 1.3;
            color: #fff;
        }

        .story.create {
            background: #242526;
        }

        .story.create .create-thumb {
            height: 72%;
            background: #d8dadf;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #65676b;
            font-size: 52px;
        }

        .story.create .plus {
            position: absolute;
            left: 50%;
            top: 68%;
            transform: translate(-50%, -50%);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--brand-500);
            border: 4px solid #242526;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
        }

        .story.create .story-name {
            bottom: 10px;
            text-align: center;
        }

        .post-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            padding: 12px 16px 8px;
        }

        .post-author {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .post-meta h4 {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
        }

        .post-meta p {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .post-tools {
            display: flex;
            gap: 8px;
            color: var(--text-muted);
        }

        .tool-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.2s;
        }

        .tool-btn:hover { background: #3a3b3c; }

        .post-text {
            padding: 0 16px 12px;
            font-size: 15px;
            line-height: 1.5;
            color: var(--text-main);
        }

        .post-image img {
            width: 100%;
            display: block;
            max-height: 560px;
            object-fit: cover;
        }

        .post-stats {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 16px;
            color: var(--text-muted);
            font-size: 14px;
        }

        .reactions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .reaction-icons {
            display: flex;
            align-items: center;
        }

        .reaction-icons span {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 10px;
            margin-right: -4px;
            border: 2px solid #242526;
        }

        .like-bg { background: var(--brand-500); }
        .love-bg { background: #f33e58; }

        .post-actions {
            border-top: 1px solid #3a3b3c;
            margin: 0 16px 8px;
            padding-top: 4px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px;
        }

        .post-action {
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--text-muted);
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .post-action:hover {
            background: #3a3b3c;
            color: #fff;
        }

        .contacts-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 8px 0 12px;
            padding: 0 8px;
        }

        .contacts-header h3 {
            font-size: 17px;
            color: var(--text-muted);
        }

        .contacts-actions {
            display: flex;
            gap: 6px;
            color: var(--text-muted);
        }

        .contacts-actions .tool-btn {
            width: 32px;
            height: 32px;
        }

        .online-dot {
            position: absolute;
            right: 0;
            bottom: 0;
            width: 11px;
            height: 11px;
            border-radius: 50%;
            background: var(--success);
            border: 2px solid var(--bg-card);
        }

        .contact-avatar {
            position: relative;
        }

        @@media (max-width: 1300px) {
            .layout {
                grid-template-columns: 280px minmax(500px, 1fr) 280px;
            }

            .nav-icon {
                width: 88px;
            }
        }

        @@media (max-width: 1100px) {
            .layout {
                grid-template-columns: 260px minmax(0, 1fr);
            }

            .contacts { display: none; }
        }

        @@media (max-width: 820px) {
            .layout {
                grid-template-columns: 1fr;
            }

            .sidebar { display: none; }
            .topbar-center { display: none; }
            .search-box { width: 180px; }
            .topbar-left, .topbar-right { min-width: auto; }
        }
    </style>
</head>
<body>
    <div class="app">
        <header class="topbar">
            <div class="topbar-left">
                <div class="logo">F</div>
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Tìm kiếm trên FPT Social" />
                </div>
            </div>

            <div class="topbar-center">
                <a href="@Url.Action("Index", "Home")" class="nav-icon active" aria-label="Trang chủ">
                    <i class="fa-solid fa-house"></i>
                </a>
                <div class="nav-icon"><i class="fa-solid fa-user-group"></i></div>
                <div class="nav-icon"><i class="fa-solid fa-tv"></i></div>
                <div class="nav-icon"><i class="fa-solid fa-store"></i></div>
                <div class="nav-icon"><i class="fa-solid fa-gamepad"></i></div>
            </div>

            <div class="topbar-right">
                <a class="circle-btn" href="@Url.Action("Index", "Conversation")" aria-label="Tin nhắn">
                    <i class="fa-solid fa-comment-dots"></i>
                </a>
                <button class="circle-btn" type="button" aria-label="Thông báo">
                    <i class="fa-solid fa-bell"></i>
                </button>
                <a class="profile-btn" href="@Url.Action("Profile", "Home")" aria-label="Trang cá nhân">
                    <i class="fa-solid fa-user"></i>
                </a>
            </div>
        </header>

        <main class="layout">
            <aside class="sidebar">
                <div class="menu-item">
                    <div class="avatar"><i class="fa-solid fa-user"></i></div>
                    <span>Mạnh Tuấn</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon orange"><i class="fa-solid fa-sparkles"></i></div>
                    <span>FPT AI</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon blue"><i class="fa-solid fa-user-group"></i></div>
                    <span>Bạn bè</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon blue"><i class="fa-solid fa-clock-rotate-left"></i></div>
                    <span>Kỷ niệm</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon purple"><i class="fa-solid fa-bookmark"></i></div>
                    <span>Đã lưu</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon blue"><i class="fa-solid fa-users"></i></div>
                    <span>Nhóm</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon red"><i class="fa-solid fa-clapperboard"></i></div>
                    <span>Thước phim</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon orange"><i class="fa-solid fa-store"></i></div>
                    <span>Marketplace</span>
                </div>
                <div class="menu-item">
                    <div class="menu-icon" style="background:#3a3b3c;color:#fff;"><i class="fa-solid fa-chevron-down"></i></div>
                    <span>Xem thêm</span>
                </div>
            </aside>

            <section class="feed">
                <div class="card create-post">
                    <div class="create-top">
                        <div class="avatar"><i class="fa-solid fa-user"></i></div>
                        <input class="post-input" type="text" placeholder="Mạnh ơi, bạn đang nghĩ gì thế?" />
                    </div>
                    <div class="create-actions">
                        <div class="create-action"><i class="fa-solid fa-video"></i>Video trực tiếp</div>
                        <div class="create-action"><i class="fa-solid fa-image"></i>Ảnh/video</div>
                        <div class="create-action"><i class="fa-regular fa-face-smile"></i>Cảm xúc</div>
                    </div>
                </div>

                <div class="card" style="padding:12px 14px;">
                    <div class="stories">
                        <div class="story create">
                            <div class="create-thumb"><i class="fa-solid fa-user"></i></div>
                            <div class="plus"><i class="fa-solid fa-plus"></i></div>
                            <div class="story-name">Tạo tin</div>
                        </div>

                        <div class="story">
                            <img class="bg" src="https://images.unsplash.com/photo-1515003197210-e0cd71810b5f?q=80&w=600&auto=format&fit=crop" alt="story" />
                            <div class="story-avatar"><img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="story-name">Alissa Nguyen</div>
                        </div>

                        <div class="story">
                            <img class="bg" src="https://images.unsplash.com/photo-1517841905240-472988babdf9?q=80&w=600&auto=format&fit=crop" alt="story" />
                            <div class="story-avatar"><img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="story-name">Phạm Linh</div>
                        </div>

                        <div class="story">
                            <img class="bg" src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600&auto=format&fit=crop" alt="story" />
                            <div class="story-avatar"><img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="story-name">Minh Tây</div>
                        </div>

                        <div class="story">
                            <img class="bg" src="https://images.unsplash.com/photo-1494790108755-2616b332c1cb?q=80&w=600&auto=format&fit=crop" alt="story" />
                            <div class="story-avatar"><img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="story-name">Howard Mind</div>
                        </div>

                        <div class="story">
                            <img class="bg" src="https://images.unsplash.com/photo-1519345182560-3f2917c472ef?q=80&w=600&auto=format&fit=crop" alt="story" />
                            <div class="story-avatar"><img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="story-name">Diệu Anh</div>
                        </div>
                    </div>
                </div>

                <article class="card">
                    <div class="post-header">
                        <div class="post-author">
                            <div class="avatar"><img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=300&auto=format&fit=crop" alt="avatar" /></div>
                            <div class="post-meta">
                                <h4>Rung Động</h4>
                                <p>Vừa xong · <i class="fa-solid fa-earth-asia"></i></p>
                            </div>
                        </div>
                        <div class="post-tools">
                            <div class="tool-btn"><i class="fa-solid fa-ellipsis"></i></div>
                            <div class="tool-btn"><i class="fa-solid fa-xmark"></i></div>
                        </div>
                    </div>

                    <div class="post-text">
                        Nguyễn Văn Hùng, tự và vô mồm 3 cái.... Xem thêm
                    </div>

                    <div class="post-image">
                        <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop" alt="post image" />
                    </div>

                    <div class="post-stats">
                        <div class="reactions">
                            <div class="reaction-icons">
                                <span class="like-bg"><i class="fa-solid fa-thumbs-up"></i></span>
                                <span class="love-bg"><i class="fa-solid fa-heart"></i></span>
                            </div>
                            <span>627</span>
                        </div>
                        <div>84 bình luận · 9 lượt chia sẻ</div>
                    </div>

                    <div class="post-actions">
                        <div class="post-action"><i class="fa-regular fa-thumbs-up"></i>Thích</div>
                        <div class="post-action"><i class="fa-regular fa-comment"></i>Bình luận</div>
                        <div class="post-action"><i class="fa-regular fa-paper-plane"></i>Gửi</div>
                    </div>
                </article>
            </section>

            <aside class="contacts">
                <div class="contacts-header">
                    <h3>Người đang theo dõi</h3>
                    <div class="contacts-actions">
                        <div class="tool-btn"><i class="fa-solid fa-magnifying-glass"></i></div>
                        <div class="tool-btn"><i class="fa-solid fa-ellipsis"></i></div>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-avatar avatar" style="background:#1f2021;">
                        <img src="https://images.unsplash.com/photo-1527980965255-d3b416303d12?q=80&w=300&auto=format&fit=crop" alt="avatar" />
                    </div>
                    <span>FPT AI</span>
                </div>

                @{
                    var followingUsers = new[]
                    {
                        "Khanh Nguyen", "Hương Phạm", "Đức Hải", "Heo Con", "Hoàng Nguyễn",
