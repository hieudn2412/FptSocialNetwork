@model FptSocialNetwork.Client.Models.HomeFeedViewModel
@{
    ViewData["Title"] = "FPT Social Home";
    Layout = null;

    var displayName = string.IsNullOrWhiteSpace(Model.CurrentUserName) ? "Người dùng" : Model.CurrentUserName.Trim();
    var avatarUrl = Model.CurrentUserAvatarUrl ?? string.Empty;
    var firstLetter = displayName.Substring(0, 1).ToUpperInvariant();
    var currentUserId = Model.CurrentUserId;
    var profileUrl = Url.Action("Profile", "Home") ?? "/Home/Profile";
}
@functions {
    private static string ToTimeAgo(DateTime createdAt)
    {
        var localTime = createdAt.Kind == DateTimeKind.Unspecified
            ? DateTime.SpecifyKind(createdAt, DateTimeKind.Utc).ToLocalTime()
            : createdAt.ToLocalTime();

        var diff = DateTime.Now - localTime;
        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày";
        return localTime.ToString("dd/MM/yyyy HH:mm");
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/social-search.css" asp-append-version="true" />
    <style>
        :root {
            --bg-page: #ffffff;
            --bg-topbar: #ffffff;
            --bg-card: #ffffff;
            --bg-soft: #f0f2f5;
            --line: #e4e6eb;
            --text-main: #080809;
            --text-muted: #65686c;
            --brand: #f37021;
            --brand-soft: rgba(243, 112, 33, 0.16);
            --success: #30a24d;
            --danger-soft: #ffe8e6;
            --social-search-bg: #ffffff;
            --social-search-border: #e4e6eb;
            --social-search-text: #080809;
            --social-search-muted: #65686c;
            --social-search-hover: #f7f8fa;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: "Manrope", "Segoe UI", Arial, sans-serif;
            background: var(--bg-page);
            color: var(--text-main);
        }

        a { text-decoration: none; color: inherit; }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 56px;
            border-bottom: 1px solid var(--line);
            background: var(--bg-topbar);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 14px;
        }

        .topbar-left, .topbar-center, .topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-left { min-width: 320px; }
        .topbar-right { min-width: 150px; justify-content: flex-end; }

        .logo {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand), #ff9c40);
            color: #fff;
            font-weight: 800;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 16px rgba(243, 112, 33, 0.35);
        }

        .search-box {
            width: 320px;
            height: 40px;
            border-radius: 999px;
            border: 1px solid transparent;
            background: #f0f2f5;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 14px;
        }

        .search-box input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            color: var(--text-main);
            font-size: 15px;
        }

        .home-link {
            width: 86px;
            height: 46px;
            border-radius: 10px;
            color: var(--brand);
            background: var(--brand-soft);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            position: relative;
            font-size: 21px;
        }

        .home-link::after {
            content: "";
            position: absolute;
            left: 18px;
            right: 18px;
            bottom: -5px;
            height: 3px;
            border-radius: 20px;
            background: var(--brand);
        }

        .icon-btn {
            position: relative;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            color: var(--text-main);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            cursor: pointer;
        }

        .post-menu-wrap { position: relative; }
        .post-menu {
            position: absolute;
            top: 44px;
            right: 0;
            width: 200px;
            background: #ffffff;
            border: 1px solid var(--line);
            border-radius: 12px;
            box-shadow: 0 16px 30px rgba(0,0,0,.16);
            padding: 6px;
            display: none;
            z-index: 1500;
        }
        .post-menu.open { display: block; }
        .post-menu-form { margin: 0; }
        .post-menu-item {
            width: 100%;
            border: none;
            background: transparent;
            height: 40px;
            border-radius: 10px;
            text-align: left;
            padding: 0 12px;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
            cursor: pointer;
        }
        .post-menu-item:hover { background: #f4f5f7; }
        .post-menu-item.danger { color: #b42318; }

        .topbar-avatar-image {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .profile-dropdown-wrap {
            position: relative;
        }

        .profile-dropdown-menu {
            position: absolute;
            top: 48px;
            right: 0;
            min-width: 210px;
            background: #fff;
            border: 1px solid #e4e6eb;
            border-radius: 12px;
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.14);
            padding: 6px;
            display: none;
            z-index: 1600;
        }

        .profile-dropdown-menu.open {
            display: block;
        }

        .social-notification-wrap { position: relative; }
        .social-notification-badge { position: absolute; top: -2px; right: -1px; min-width: 18px; height: 18px; border-radius: 999px; background: #ef4444; color: #fff; font-size: 11px; font-weight: 800; display: inline-flex; align-items: center; justify-content: center; padding: 0 5px; border: 2px solid #fff; }
        .social-notification-dropdown { position: absolute; top: 48px; right: 0; width: min(360px, calc(100vw - 24px)); max-height: 420px; overflow-y: auto; background: #fff; border: 1px solid #e4e6eb; border-radius: 14px; box-shadow: 0 18px 36px rgba(0, 0, 0, 0.16); padding: 8px; display: none; z-index: 1700; }
        .social-notification-dropdown.open { display: block; }
        .social-notification-title { font-size: 18px; font-weight: 800; padding: 6px 8px 10px; }
        .social-notification-empty { color: var(--text-muted); font-size: 14px; padding: 14px 8px; text-align: center; }
        .social-notification-list { display: grid; gap: 6px; }
        .social-notification-item { width: 100%; border: none; background: #fff; border-radius: 12px; text-align: left; padding: 10px; display: grid; grid-template-columns: 38px 1fr; gap: 10px; cursor: pointer; }
        .social-notification-item:hover { background: #f7f8fa; }
        .social-notification-item.unread { background: #eef5ff; }
        .social-notification-icon { width: 38px; height: 38px; border-radius: 50%; background: var(--brand-soft); color: var(--brand); display: inline-flex; align-items: center; justify-content: center; }
        .social-notification-copy { display: grid; gap: 4px; }
        .social-notification-copy strong { font-size: 14px; }
        .social-notification-copy span { font-size: 13px; color: var(--text-main); line-height: 1.4; }
        .social-notification-copy small { color: var(--text-muted); font-size: 12px; }
        .social-toast-host { position: fixed; right: 18px; bottom: 18px; z-index: 4000; display: grid; gap: 10px; }
        .social-toast { min-width: 240px; max-width: 320px; background: rgba(8, 8, 9, 0.92); color: #fff; border-radius: 12px; padding: 12px 14px; box-shadow: 0 16px 30px rgba(0, 0, 0, 0.22); transition: opacity .3s ease, transform .3s ease; }
        .social-toast.hide { opacity: 0; transform: translateY(8px); }

        .profile-menu-item {
            width: 100%;
            border: none;
            background: transparent;
            text-decoration: none;
            color: #080809;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            height: 40px;
            padding: 0 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .profile-menu-item:hover {
            background: #f2f3f5;
        }

        .layout {
            max-width: 1500px;
            margin: 0 auto;
            padding: 16px;
            display: grid;
            grid-template-columns: 290px minmax(500px, 1fr) 290px;
            gap: 18px;
        }

        .panel {
            position: sticky;
            top: 72px;
            height: calc(100vh - 88px);
            overflow-y: auto;
            padding-right: 4px;
        }

        .panel::-webkit-scrollbar { width: 7px; }
        .panel::-webkit-scrollbar-thumb { background: #c8ccd4; border-radius: 8px; }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--line);
            border-radius: 14px;
            box-shadow: 0 1px 2px rgba(0,0,0,.3);
        }

        .menu-item {
            display: flex;
            gap: 10px;
            align-items: center;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--text-main);
            font-weight: 600;
        }

        .menu-item:hover { background: #f2f3f5; }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #dce0e6;
            color: #69717d;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
        }

        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .composer {
            padding: 14px;
            margin-bottom: 14px;
        }

        .composer-top {
            display: flex;
            gap: 10px;
            align-items: center;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--line);
        }

        .composer-trigger {
            flex: 1;
            height: 42px;
            border: none;
            border-radius: 999px;
            background: var(--bg-soft);
            color: var(--text-muted);
            text-align: left;
            padding: 0 16px;
            font-size: 15px;
            cursor: pointer;
        }

        .composer-actions {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin-top: 8px;
        }

        .composer-action {
            height: 38px;
            border-radius: 8px;
            color: var(--text-muted);
            font-weight: 700;
            font-size: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: none;
            background: transparent;
        }

        .composer-action:hover { background: #f2f3f5; color: #1c1e21; }
        .composer-action .fa-video { color: #f3425f; }
        .composer-action .fa-image { color: #45bd62; }
        .composer-action .fa-paper-plane { color: #74b8ff; }

        .post-card { margin-bottom: 14px; overflow: hidden; }

        .post-header {
            display: flex;
            justify-content: space-between;
            padding: 12px 14px 8px;
        }

        .post-author {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .post-author h4 {
            font-size: 15px;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .post-author p {
            color: var(--text-muted);
            font-size: 13px;
        }

        .post-content {
            padding: 0 14px 10px;
            line-height: 1.5;
            font-size: 15px;
            white-space: pre-wrap;
        }

        .post-image img {
            width: 100%;
            max-height: 560px;
            object-fit: cover;
            display: block;
            border-top: 1px solid var(--line);
            border-bottom: 1px solid var(--line);
        }

        .post-stats {
            padding: 10px 14px;
            color: var(--text-muted);
            font-size: 14px;
            display: flex;
            justify-content: space-between;
        }

        .post-actions {
            margin: 0 14px 10px;
            border-top: 1px solid var(--line);
            padding-top: 5px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px;
        }

        .post-action-form { margin: 0; }

        .post-action-btn {
            width: 100%;
            border: none;
            background: transparent;
            border-radius: 8px;
            height: 36px;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 700;
            display: flex;
            gap: 8px;
            justify-content: center;
            align-items: center;
            cursor: pointer;
        }

        .post-action-btn:hover { background: #f2f3f5; color: #1c1e21; }
        .post-action-btn.active { color: var(--brand); }

        .follow-form { margin: 0; }

        .follow-btn {
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: #ffffff;
            color: var(--text-main);
            padding: 0 12px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
        }

        .follow-btn:hover { border-color: #c6cbd3; }
        .follow-btn.following { color: var(--brand); border-color: rgba(243, 112, 33, 0.44); }

        .comment-list {
            margin: 0 14px 10px;
            display: grid;
            gap: 8px;
        }

        .comment-empty {
            background: #f5f6f8;
            border-radius: 10px;
            padding: 10px 12px;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
        }

        .shared-card {
            margin: 10px 14px;
            border: 1px solid var(--line);
            border-radius: 12px;
            background: #f7f8fa;
            overflow: hidden;
        }

        .shared-head {
            display: flex;
            gap: 10px;
            align-items: center;
            padding: 10px 12px;
            border-bottom: 1px solid var(--line);
        }

        .shared-head .avatar {
            width: 32px;
            height: 32px;
        }

        .shared-body {
            padding: 10px 12px 12px;
            display: grid;
            gap: 8px;
        }

        .shared-body .shared-content {
            font-size: 14px;
            color: var(--text-main);
            white-space: pre-wrap;
            line-height: 1.45;
        }

        .comment-item {
            background: #f5f6f8;
            border-radius: 10px;
            padding: 8px 10px;
        }

        .comment-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
            color: var(--text-muted);
            font-size: 12px;
        }

        .comment-content {
            color: var(--text-main);
            font-size: 14px;
            line-height: 1.4;
            white-space: pre-wrap;
        }

        .comment-form {
            margin: 0 14px 12px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 8px;
        }

        .comment-input {
            height: 38px;
            border-radius: 10px;
            border: 1px solid var(--line);
            background: #ffffff;
            color: var(--text-main);
            padding: 0 12px;
            outline: none;
            font-size: 14px;
        }

        .comment-submit {
            height: 38px;
            border: none;
            border-radius: 10px;
            padding: 0 14px;
            background: #1877f2;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
        }

        .section-head {
            color: var(--text-muted);
            font-size: 18px;
            font-weight: 800;
            margin: 6px 8px 12px;
        }

        .contact-item {
            display: flex;
            gap: 10px;
            align-items: center;
            border-radius: 10px;
            padding: 8px;
            color: var(--text-main);
            font-weight: 700;
        }

        .contact-item:hover { background: #f2f3f5; }

        .online-dot {
            position: relative;
        }

        .online-dot::after {
            content: "";
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: var(--success);
            border: 2px solid var(--bg-card);
            position: absolute;
            right: -1px;
            bottom: -1px;
        }

        .error-banner {
            padding: 10px 12px;
            border-color: #8c2f2f;
            background: var(--danger-soft);
            color: #8a1f1f;
            margin-bottom: 12px;
        }

        .empty-state {
            padding: 28px 16px;
            text-align: center;
            color: var(--text-muted);
            font-weight: 600;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(8, 10, 14, 0.72);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3000;
            padding: 12px;
        }

        .modal-backdrop[hidden] { display: none; }

        .post-modal {
            width: min(560px, 100%);
            background: #ffffff;
            border: 1px solid #e4e6eb;
            border-radius: 16px;
            overflow: hidden;
        }

        .modal-head {
            height: 62px;
            border-bottom: 1px solid var(--line);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            font-size: 32px;
            font-weight: 800;
        }

        .modal-close {
            position: absolute;
            right: 14px;
            top: 12px;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            color: #4b5563;
            cursor: pointer;
            font-size: 18px;
        }

        .modal-content { padding: 14px; }

        .modal-author {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .modal-author strong { font-size: 15px; }

        .modal-textarea {
            width: 100%;
            min-height: 130px;
            border: none;
            outline: none;
            resize: vertical;
            border-radius: 12px;
            background: #f7f8fa;
            color: var(--text-main);
            padding: 12px;
            font-size: 18px;
            font-family: inherit;
            line-height: 1.5;
        }

        .preview-wrap {
            margin-top: 10px;
            border-radius: 12px;
            border: 1px solid var(--line);
            overflow: hidden;
        }

        .preview-wrap img {
            width: 100%;
            max-height: 280px;
            object-fit: cover;
            display: block;
        }

        .modal-tools {
            margin-top: 12px;
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }

        .modal-tool-label { font-weight: 700; color: var(--text-main); }

        .modal-tool-btn {
            border: none;
            background: transparent;
            color: var(--text-muted);
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .modal-tool-btn .fa-image { color: #45bd62; }

        .submit-btn {
            width: 100%;
            height: 42px;
            border: none;
            border-radius: 10px;
            margin-top: 12px;
            background: var(--brand);
            color: #fff;
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
        }

        .submit-btn:hover { filter: brightness(1.05); }

        @@media (max-width: 1200px) {
            .layout { grid-template-columns: 260px minmax(0, 1fr); }
            .panel.right { display: none; }
        }

        @@media (max-width: 880px) {
            .layout { grid-template-columns: 1fr; }
            .panel.left { display: none; }
            .search-box { width: 190px; }
            .topbar-center { display: none; }
            .topbar-left { min-width: auto; }
            .modal-head { font-size: 26px; }
            .modal-textarea { font-size: 17px; }
        }
    </style>
</head>
<body data-social-realtime
      data-social-page="index"
      data-social-hub-url="@Model.SocialHubUrl"
      data-realtime-token="@Model.RealtimeToken"
      data-current-user-id="@Model.CurrentUserId"
      data-viewed-user-id="@Model.ViewedUserId">
    <header class="topbar">
        <div class="topbar-left">
            <a class="logo" href="@Url.Action("Index", "Home")">F</a>
            <div class="search-box" data-user-search>
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm trên FPT Social" data-user-search-input />
                <div data-user-search-results hidden></div>
            </div>
        </div>

        <div class="topbar-center">
            <a class="home-link" href="@Url.Action("Index", "Home")" aria-label="Trang chủ">
                <i class="fa-solid fa-house"></i>
            </a>
        </div>

        <div class="topbar-right">
            <a class="icon-btn" href="@Url.Action("Index", "Conversation")" aria-label="Tin nhắn">
                <i class="fa-solid fa-comment-dots"></i>
            </a>
            <div class="social-notification-wrap">
                <button class="icon-btn" id="socialNotificationToggle" type="button" aria-label="Thông báo" aria-haspopup="true" aria-expanded="false">
                    <i class="fa-solid fa-bell"></i>
                    <span class="social-notification-badge" id="socialNotificationBadge" hidden>0</span>
                </button>
                <div class="social-notification-dropdown" id="socialNotificationDropdown">
                    <div class="social-notification-title">Thông báo</div>
                    <div class="social-notification-empty" id="socialNotificationEmpty">Chưa có thông báo mới.</div>
                    <div class="social-notification-list" id="socialNotificationList"></div>
                </div>
            </div>
            <div class="profile-dropdown-wrap">
                <button class="icon-btn" type="button" id="homeProfileToggle" aria-label="Tài khoản" aria-haspopup="true" aria-expanded="false">
                    @if (!string.IsNullOrWhiteSpace(avatarUrl))
                    {
                        <img class="topbar-avatar-image" src="@avatarUrl" alt="avatar" />
                    }
                    else
                    {
                        <i class="fa-solid fa-user"></i>
                    }
                </button>
                <div class="profile-dropdown-menu" id="homeProfileDropdown">
                    <a class="profile-menu-item" href="@profileUrl">
                        <i class="fa-solid fa-circle-user"></i>
                        <span>Trang cá nhân</span>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="profile-menu-item" type="submit">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span>Đăng xuất</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <main class="layout">
        <aside class="panel left">
            <div class="card" style="padding:8px;">
                <a class="menu-item" href="@Url.Action("Profile", "Home")">
                    <span class="avatar">
                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="avatar" />
                        }
                        else
                        {
                            <span>@firstLetter</span>
                        }
                    </span>
                    <span>@displayName</span>
                </a>
                <a class="menu-item" href="@Url.Action("Index", "Home")">
                    <span class="avatar" style="background:var(--brand-soft);color:var(--brand);">
                        <i class="fa-solid fa-house"></i>
                    </span>
                    <span>Bảng tin</span>
                </a>
                <a class="menu-item" href="@Url.Action("Index", "Conversation")">
                    <span class="avatar" style="background:#e7f3ff;color:#1877f2;">
                        <i class="fa-solid fa-comments"></i>
                    </span>
                    <span>Tin nhắn</span>
                </a>
            </div>
        </aside>

        <section data-post-feed="index">
            @if (!string.IsNullOrWhiteSpace(Model.PostError))
            {
                <div class="card error-banner">@Model.PostError</div>
            }

            <div class="card composer">
                <div class="composer-top">
                    <span class="avatar">
                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="avatar" />
                        }
                        else
                        {
                            <span>@firstLetter</span>
                        }
                    </span>
                    <button type="button" class="composer-trigger" data-open-post-modal>@Model.ComposerPlaceholder</button>
                </div>
                <div class="composer-actions">
                    <button type="button" class="composer-action" data-open-post-modal><i class="fa-solid fa-video"></i>Video trực tiếp</button>
                    <button type="button" class="composer-action" data-open-post-modal><i class="fa-solid fa-image"></i>Ảnh/video</button>
                    <button type="button" class="composer-action" data-open-post-modal><i class="fa-solid fa-paper-plane"></i>Đăng bài</button>
                </div>
            </div>

            @if (Model.Posts.Count == 0)
            {
                <div class="card empty-state" data-empty-posts>Chưa có bài viết nào trong bảng tin.</div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    var authorName = string.IsNullOrWhiteSpace(post.AuthorName) ? "Người dùng" : post.AuthorName;
                    var authorInitial = authorName.Substring(0, 1).ToUpperInvariant();
                    var authorProfileUrl = Url.Action("Profile", "Home", new { userId = post.UserId }) ?? $"/Home/Profile/{post.UserId}";
                    <article class="card post-card" data-post-id="@post.Id">
                        <div class="post-header">
                            <a class="post-author" href="@authorProfileUrl">
                                <span class="avatar">
                                    @if (!string.IsNullOrWhiteSpace(post.AuthorAvatarUrl))
                                    {
                                        <img src="@post.AuthorAvatarUrl" alt="avatar" />
                                    }
                                    else
                                    {
                                        <span>@authorInitial</span>
                                    }
                                </span>
                                <div>
                                    <h4>@authorName</h4>
                                    <p>@ToTimeAgo(post.CreatedAt) · <i class="fa-solid fa-earth-asia"></i></p>
                                </div>
                            </a>
                            <div style="display:flex; align-items:center; gap:8px;">
                                @if (currentUserId > 0 && post.UserId != currentUserId)
                                {
                                    <form class="follow-form" asp-controller="Home" asp-action="ToggleFollow" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="targetUserId" value="@post.UserId" />
                                        <input type="hidden" name="source" value="index" />
                                        <button class="follow-btn @(post.IsAuthorFollowedByCurrentUser ? "following" : string.Empty)" type="submit">
                                            @(post.IsAuthorFollowedByCurrentUser ? "Bỏ theo dõi" : "Theo dõi")
                                        </button>
                                    </form>
                                }
                                <div class="post-menu-wrap">
                                    <button class="icon-btn post-menu-toggle" type="button" aria-label="Tùy chọn">
                                        <i class="fa-solid fa-ellipsis"></i>
                                    </button>
                                    @if (post.UserId == currentUserId)
                                    {
                                        <div class="post-menu">
                                            <button class="post-menu-item" type="button" data-edit-post>Chỉnh sửa bài viết</button>
                                            <form class="post-menu-form post-delete-form" asp-controller="Home" asp-action="DeletePost" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="postId" value="@post.Id" />
                                                <input type="hidden" name="source" value="index" />
                                                <button class="post-menu-item danger" type="submit">Xóa bài viết</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(post.Content))
                        {
                            <div class="post-content">@post.Content</div>
                        }

                        @if (post.SourcePostId.HasValue)
                        {
                            var sourceProfileUrl = Url.Action("Profile", "Home", new { userId = post.SourceUserId ?? 0 }) ?? $"/Home/Profile/{post.SourceUserId}";
                            var sourceInitial = (post.SourceAuthorName ?? "Người dùng").Substring(0,1).ToUpperInvariant();
                            <div class="shared-card" data-source-post-id="@post.SourcePostId">
                                <div class="shared-head">
                                    <span class="avatar">
                                        @if (!string.IsNullOrWhiteSpace(post.SourceAuthorAvatarUrl))
                                        {
                                            <img src="@post.SourceAuthorAvatarUrl" alt="avatar" />
                                        }
                                        else
                                        {
                                            <span>@sourceInitial</span>
                                        }
                                    </span>
                                    <div>
                                        <a href="@sourceProfileUrl"><strong>@(string.IsNullOrWhiteSpace(post.SourceAuthorName) ? "Người dùng" : post.SourceAuthorName)</strong></a>
                                        <p style="color:var(--text-muted); font-size:12px;">@ToTimeAgo(post.SourceCreatedAt ?? post.CreatedAt)</p>
                                    </div>
                                </div>
                                <div class="shared-body">
                                    @if (post.SourcePostDeleted)
                                    {
                                        <div class="shared-content">Nội dung này không còn tồn tại.</div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(post.SourceContent))
                                    {
                                        <div class="shared-content">@post.SourceContent</div>
                                    }
                                    @if (!post.SourcePostDeleted && !string.IsNullOrWhiteSpace(post.SourceMediaUrl))
                                    {
                                        <div class="post-image">
                                            <img src="@post.SourceMediaUrl" alt="shared media" />
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (!post.SourcePostId.HasValue && !string.IsNullOrWhiteSpace(post.MediaUrl))
                        {
                            <div class="post-image">
                                <img src="@post.MediaUrl" alt="post image" />
                            </div>
                        }

                        <div class="post-stats">
                            <span data-like-count>@post.LikeCount lượt thích</span>
                            <span data-comment-count>@post.CommentCount bình luận</span>
                        </div>

                        <div class="post-actions">
                                <form class="post-action-form" asp-controller="Home" asp-action="ToggleReaction" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="source" value="index" />
                                    <button class="post-action-btn @(post.IsLikedByCurrentUser ? "active" : string.Empty)" type="submit">
                                        <i class="@(post.IsLikedByCurrentUser ? "fa-solid" : "fa-regular") fa-thumbs-up"></i><span data-like-label>@(post.IsLikedByCurrentUser ? "Bỏ thích" : "Thích")</span>
                                    </button>
                                </form>
                            <button class="post-action-btn" type="button" data-focus-comment="comment-@post.Id">
                                <i class="fa-regular fa-comment"></i>Bình luận
                            </button>
                            <form class="post-action-form" asp-controller="Home" asp-action="SharePost" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@post.Id" />
                                <input type="hidden" name="source" value="index" />
                                <button class="post-action-btn" type="submit">
                                    <i class="fa-regular fa-paper-plane"></i>Chia sẻ
                                </button>
                            </form>
                        </div>

                        <div class="comment-list" data-comment-list>
                            @if (post.RecentComments.Count == 0)
                            {
                                <div class="comment-empty" data-comment-empty>Chưa có bình luận nào.</div>
                            }
                            else
                            {
                                @foreach (var comment in post.RecentComments.OrderBy(c => c.CreatedAt))
                                {
                                    var commentAuthorProfileUrl = Url.Action("Profile", "Home", new { userId = comment.UserId }) ?? $"/Home/Profile/{comment.UserId}";
                                    <div class="comment-item">
                                        <div class="comment-meta">
                                            <a href="@commentAuthorProfileUrl"><strong>@comment.AuthorName</strong></a>
                                            <span>@ToTimeAgo(comment.CreatedAt)</span>
                                        </div>
                                        <div class="comment-content">@comment.Content</div>
                                    </div>
                                }
                            }
                        </div>

                        <form class="comment-form" asp-controller="Home" asp-action="AddComment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@post.Id" />
                            <input type="hidden" name="source" value="index" />
                            <input id="comment-@post.Id" class="comment-input" type="text" name="content" maxlength="500" placeholder="Viết bình luận..." />
                            <button class="comment-submit" type="submit">Gửi</button>
                        </form>
                    </article>
                }
            }
        </section>

        <aside class="panel right">
            <div class="section-head">Người đang theo dõi</div>
            <div class="card" style="padding:8px;">
                @if (Model.FollowingUsers.Count == 0)
                {
                    <div class="empty-state" style="padding:14px;">Chưa có dữ liệu người theo dõi.</div>
                }
                else
                {
                    @foreach (var user in Model.FollowingUsers)
                    {
                        var contactInitial = string.IsNullOrWhiteSpace(user.DisplayName)
                            ? "U"
                            : user.DisplayName.Substring(0, 1).ToUpperInvariant();

                        <div class="contact-item">
                            <span class="avatar online-dot">
                                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                                {
                                    <img src="@user.AvatarUrl" alt="avatar" />
                                }
                                else
                                {
                                    <span>@contactInitial</span>
                                }
                            </span>
                            <span>@user.DisplayName</span>
                        </div>
                    }
                }
            </div>
        </aside>
    </main>

    <div class="modal-backdrop" id="post-modal" hidden>
        <div class="post-modal">
            <div class="modal-head">
                Tạo bài viết
                <button class="modal-close" type="button" data-close-post-modal><i class="fa-solid fa-xmark"></i></button>
            </div>
            <form class="modal-content" asp-controller="Home" asp-action="CreatePost" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Source" value="index" />
                <div class="modal-author">
                    <span class="avatar">
                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="avatar" />
                        }
                        else
                        {
                            <span>@firstLetter</span>
                        }
                    </span>
                    <strong>@displayName</strong>
                </div>
                <textarea class="modal-textarea" name="Content" maxlength="2000" placeholder="Bạn đang nghĩ gì?" autofocus></textarea>
                <div class="preview-wrap" id="post-image-preview-wrap" hidden>
                    <img id="post-image-preview" alt="preview" />
                </div>
                <div class="modal-tools">
                    <span class="modal-tool-label">Thêm vào bài viết của bạn</span>
                    <label class="modal-tool-btn" for="post-image-file"><i class="fa-solid fa-image"></i>Ảnh/video</label>
                </div>
                <input id="post-image-file" type="file" name="Image" accept="image/*" hidden />
                <button class="submit-btn" type="submit">Đăng</button>
            </form>
        </div>
    </div>

    <div class="modal-backdrop" id="edit-post-modal" hidden>
        <div class="post-modal">
            <div class="modal-head">
                Chỉnh sửa bài viết
                <button class="modal-close" type="button" data-close-edit-post-modal><i class="fa-solid fa-xmark"></i></button>
            </div>
            <form class="modal-content" id="edit-post-form" asp-controller="Home" asp-action="EditPost" method="post">
                @Html.AntiForgeryToken()
                <input id="edit-post-id" type="hidden" name="postId" />
                <input id="edit-post-source" type="hidden" name="source" value="index" />
                <div class="modal-author">
                    <span class="avatar">
                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="avatar" />
                        }
                        else
                        {
                            <span>@firstLetter</span>
                        }
                    </span>
                    <strong>@displayName</strong>
                </div>
                <textarea class="modal-textarea" id="edit-post-textarea" name="content" maxlength="2000" placeholder="Bạn đang nghĩ gì?"></textarea>
                <button class="submit-btn" type="submit">Lưu thay đổi</button>
            </form>
        </div>
    </div>

    <div class="social-toast-host" id="socialToastHost"></div>

    <script src="https://cdn.jsdelivr.net/npm/%40microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/social-realtime.js"></script>
    <script src="~/js/social-search.js" asp-append-version="true"></script>
    <script src="~/js/social-actions.js" asp-append-version="true"></script>
    <script>
        (() => {
            const postModal = document.getElementById("post-modal");
            const openPostModalButtons = document.querySelectorAll("[data-open-post-modal]");
            const closePostModalButton = document.querySelector("[data-close-post-modal]");
            const imageInput = document.getElementById("post-image-file");
            const imagePreviewWrap = document.getElementById("post-image-preview-wrap");
            const imagePreview = document.getElementById("post-image-preview");
            const commentFocusButtons = document.querySelectorAll("[data-focus-comment]");
            const profileToggle = document.getElementById("homeProfileToggle");
            const profileDropdown = document.getElementById("homeProfileDropdown");

            const openPostModal = () => {
                postModal.hidden = false;
                document.body.style.overflow = "hidden";
            };

            const closePostModal = () => {
                postModal.hidden = true;
                document.body.style.overflow = "";
            };

            openPostModalButtons.forEach(button => button.addEventListener("click", openPostModal));
            closePostModalButton?.addEventListener("click", closePostModal);

            postModal?.addEventListener("click", (event) => {
                if (event.target === postModal) {
                    closePostModal();
                }
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && !postModal.hidden) {
                    closePostModal();
                }
                if (event.key === "Escape" && profileDropdown) {
                    profileDropdown.classList.remove("open");
                    if (profileToggle) {
                        profileToggle.setAttribute("aria-expanded", "false");
                    }
                }
            });

            profileToggle?.addEventListener("click", (event) => {
                if (!profileDropdown) return;
                event.stopPropagation();
                const willOpen = !profileDropdown.classList.contains("open");
                profileDropdown.classList.toggle("open", willOpen);
                profileToggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
            });

            document.addEventListener("click", (event) => {
                if (!profileDropdown || !profileToggle) return;
                if (profileDropdown.contains(event.target) || profileToggle.contains(event.target)) {
                    return;
                }

                profileDropdown.classList.remove("open");
                profileToggle.setAttribute("aria-expanded", "false");
            });

            imageInput?.addEventListener("change", () => {
                const file = imageInput.files && imageInput.files[0];
                if (!file) {
                    imagePreviewWrap.hidden = true;
                    imagePreview.removeAttribute("src");
                    return;
                }

                const reader = new FileReader();
                reader.onload = (loadEvent) => {
                    imagePreview.src = String(loadEvent.target?.result || "");
                    imagePreviewWrap.hidden = false;
                };
                reader.readAsDataURL(file);
            });

            commentFocusButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const targetId = button.getAttribute("data-focus-comment");
                    if (!targetId) {
                        return;
                    }

                    const targetInput = document.getElementById(targetId);
                    targetInput?.focus();
                });
            });

        })();
    </script>
</body>
</html>
