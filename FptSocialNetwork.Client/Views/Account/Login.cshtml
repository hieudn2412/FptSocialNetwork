@model FptSocialNetwork.Client.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div style="max-width:420px;margin:60px auto;padding:24px;border:1px solid #ddd;border-radius:8px;">
    <h2 style="margin-bottom:16px;">Đăng nhập</h2>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div style="color:#c62828;margin-bottom:12px;">@Model.ErrorMessage</div>
    }
    <form method="post">
        @Html.AntiForgeryToken()
        <div style="margin-bottom:12px;">
            <label>Email</label>
            <input asp-for="Email" style="width:100%;padding:8px;" />
            <span asp-validation-for="Email" style="color:#c62828;"></span>
        </div>
        <div style="margin-bottom:12px;">
            <label>Password</label>
            <input asp-for="Password" style="width:100%;padding:8px;" />
            <span asp-validation-for="Password" style="color:#c62828;"></span>
        </div>
        <button type="submit" style="padding:8px 12px;">Đăng nhập</button>
    </form>
    <div style="display:flex;align-items:center;gap:10px;margin:14px 0;">
        <div style="height:1px;background:#e0e0e0;flex:1;"></div>
        <span style="color:#666;font-size:13px;">hoặc</span>
        <div style="height:1px;background:#e0e0e0;flex:1;"></div>
    </div>
    <form id="googleLoginForm" method="post" asp-action="GoogleLogin">
        @Html.AntiForgeryToken()
        <input type="hidden" id="googleIdToken" name="idToken" />
    </form>
    @if (!string.IsNullOrWhiteSpace((string?)ViewBag.GoogleClientId))
    {
        <div id="g_id_onload"
             data-client_id="@ViewBag.GoogleClientId"
             data-callback="onGoogleCredentialResponse"
             data-auto_prompt="false"></div>
        <div class="g_id_signin"
             data-type="standard"
             data-size="large"
             data-theme="outline"
             data-text="signin_with"
             data-shape="rectangular"
             data-logo_alignment="left"></div>
    }
    else
    {
        <div style="font-size:13px;color:#c62828;">Thiếu cấu hình GoogleAuth:ClientId.</div>
    }
    <p style="margin-top:12px;">Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký</a></p>
</div>

<partial name="_ValidationScriptsPartial" />

@if (!string.IsNullOrWhiteSpace((string?)ViewBag.GoogleClientId))
{
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        function onGoogleCredentialResponse(response) {
            if (!response || !response.credential) {
                return;
            }

            var tokenInput = document.getElementById("googleIdToken");
            var form = document.getElementById("googleLoginForm");
            if (!tokenInput || !form) {
                return;
            }

            tokenInput.value = response.credential;
            form.submit();
        }
    </script>
}
