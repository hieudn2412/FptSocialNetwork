@model FptSocialNetwork.Client.Models.ConversationPageViewModel
@using System.Text.Json

@{
    Layout = null;
    ViewBag.Title = "Messenger UI Clone";
    var currentUserId = Model.CurrentUserId;
    var selectedConversation = Model.SelectedConversation;
    var selectedConversationName = selectedConversation?.Name ?? "Chưa chọn đoạn chat";
    var selectedConversationAvatar = selectedConversation?.AvatarUrl;
    var selectedMembers = selectedConversation?.Members ?? new List<DataAccessLayer.Services.Models.ConversationMemberDto>();
    var isGroupConversation = string.Equals(selectedConversation?.Type, "group", StringComparison.OrdinalIgnoreCase);
    var hasCustomGroupAvatar = isGroupConversation && !string.IsNullOrWhiteSpace(selectedConversationAvatar);
    var activeTab = (Model.Tab ?? "all").Trim().ToLowerInvariant();
    var lastMessageId = Model.Messages.LastOrDefault()?.Id ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global-navbar.css" asp-append-version="true" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        html, body {
            height: 100%;
        }

        body {
            background: #f0f2f5;
            overflow: hidden;
            color: #050505;
        }

        .app {
            display: grid;
            grid-template-columns: 420px 1fr 420px;
            height: calc(100vh - var(--fb-nav-height, 76px));
            width: 100%;
            transition: grid-template-columns 0.2s ease;
        }

        .app.right-panel-collapsed {
            grid-template-columns: 420px 1fr 0;
        }

        .app.right-panel-collapsed .right-panel {
            width: 0;
            padding: 0;
            border-left: none;
            overflow: hidden;
        }

        .sidebar,
        .chat-area,
        .right-panel {
            background: #fff;
        }

        /* LEFT SIDEBAR */
        .sidebar {
            border-right: 1px solid #e4e6eb;
            display: flex;
            flex-direction: column;
            padding: 16px 10px 0;
            height: 100%;
            overflow: hidden;
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 8px 12px;
            flex-shrink: 0;
        }

        .sidebar-header h1 {
            font-size: 24px;
            font-weight: 700;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #050505;
            border: none;
            cursor: pointer;
        }

        .create-group-modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.28);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 30;
            padding: 20px;
        }

        .create-group-modal.open {
            display: flex;
        }

        .create-group-card {
            width: min(520px, 96vw);
            max-height: 86vh;
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
        }

        .create-group-header {
            height: 64px;
            border-bottom: 1px solid #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
        }

        .create-group-header h3 {
            font-size: 22px;
            font-weight: 700;
        }

        .create-group-body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 0;
        }

        .create-group-search-box {
            border-radius: 999px;
            background: #f0f2f5;
            padding: 12px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #65676b;
        }

        .create-group-search-box input {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            font-size: 15px;
            color: #1c1e21;
        }

        .create-group-name {
            border: 1px solid #d9dde3;
            border-radius: 12px;
            padding: 10px 12px;
            font-size: 15px;
            outline: none;
        }

        .create-group-name:focus {
            border-color: #1877f2;
        }

        .selected-member-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            min-height: 30px;
        }

        .selected-member-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #e7f3ff;
            color: #1c1e21;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 14px;
            font-weight: 600;
        }

        .selected-member-chip button {
            border: none;
            background: transparent;
            color: #51677a;
            cursor: pointer;
            padding: 0;
            font-size: 13px;
            line-height: 1;
        }

        .create-group-results {
            border-top: 1px solid #e4e6eb;
            padding-top: 10px;
            overflow-y: auto;
            min-height: 180px;
            max-height: 320px;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .create-group-user-item {
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            border-radius: 12px;
            padding: 10px 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

        .create-group-user-item:hover {
            background: #f2f3f5;
        }

        .create-group-user-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .create-group-user-meta img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            background: #d8dadf;
        }

        .create-group-user-text {
            min-width: 0;
        }

        .create-group-user-text strong {
            display: block;
            font-size: 15px;
            color: #1c1e21;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .create-group-user-text span {
            display: block;
            margin-top: 2px;
            font-size: 13px;
            color: #65676b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .create-group-user-check {
            color: #1877f2;
            font-size: 18px;
            flex-shrink: 0;
            margin-left: 10px;
        }

        .create-group-empty {
            font-size: 14px;
            color: #65676b;
            padding: 10px 8px;
        }

        .create-group-footer {
            border-top: 1px solid #e4e6eb;
            padding: 12px 16px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .create-group-btn {
            border: none;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .create-group-btn.secondary {
            background: #e4e6eb;
            color: #1c1e21;
        }

        .create-group-btn.primary {
            background: #1877f2;
            color: #fff;
        }

        .create-group-btn[disabled] {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .search-box {
            background: #f0f2f5;
            border-radius: 999px;
            padding: 13px 16px;
            margin: 0 8px 18px;
            color: #65676b;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .tabs {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 8px 16px;
            flex-shrink: 0;
        }

        .tab {
            padding: 10px 14px;
            border-radius: 999px;
            font-size: 16px;
            font-weight: 600;
            color: #050505;
            cursor: pointer;
            white-space: nowrap;
        }

        .tab.active {
            background: #e7f3ff;
            color: #1877f2;
        }

        /* SCROLL 1 */
        .chat-list {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-right: 6px;
            min-height: 0;
        }

        .conversation-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 9px 10px;
            border-radius: 12px;
            cursor: pointer;
            margin-bottom: 2px;
        }

        .conversation-item:hover {
            background: #f2f2f2;
        }

        .conversation-item.active {
            background: #e7f0fb;
        }

        .conversation-list-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 10px;
            border-radius: 12px;
            margin-bottom: 2px;
        }

        .conversation-list-item:hover {
            background: #f2f2f2;
        }

        .conversation-list-item.active {
            background: #e7f0fb;
        }

        .conversation-item-link {
            flex: 1;
            min-width: 0;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: inherit;
        }

        .conversation-trailing {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            min-height: 28px;
        }

        .conversation-actions {
            position: relative;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.16s ease;
        }

        .conversation-list-item:hover .conversation-actions,
        .conversation-list-item.menu-open .conversation-actions {
            opacity: 1;
            pointer-events: auto;
        }

        .conversation-more-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: #ffffff;
            color: #65676b;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }

        .conversation-more-btn:hover {
            background: #e4e6eb;
            color: #1c1e21;
        }

        .conversation-more-menu {
            position: absolute;
            top: calc(100% + 6px);
            right: 0;
            min-width: 176px;
            background: #fff;
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18);
            border: 1px solid #e4e6eb;
            display: none;
            z-index: 120;
        }

        .conversation-more-menu.open {
            display: block;
        }

        .conversation-menu-item {
            width: 100%;
            border: none;
            border-radius: 8px;
            background: transparent;
            text-align: left;
            padding: 10px 12px;
            font-size: 15px;
            font-weight: 600;
            color: #050505;
            cursor: pointer;
        }

        .conversation-menu-item:hover {
            background: #f0f2f5;
        }

        .conversation-menu-item.danger {
            color: #d93025;
        }

        .avatar-wrap {
            position: relative;
            width: 56px;
            height: 56px;
            flex-shrink: 0;
        }

        .avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            object-fit: cover;
            background: #d8dadf;
        }

        .small-badge {
            position: absolute;
            right: -2px;
            bottom: -2px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #bcc0c4;
            border: 2px solid #fff;
        }

        .conversation-content {
            flex: 1;
            min-width: 0;
        }

        .conversation-name {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 4px;
            line-height: 20px;
            color: #080809;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .conversation-preview {
            font-size: 13px;
            color: #65686c;
            line-height: 17px;
            padding-bottom: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .conversation-preview.unread {
            color: #050505;
            font-weight: 700;
        }

        .unread-badge {
            min-width: 22px;
            height: 22px;
            border-radius: 999px;
            background: #1877f2;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            padding: 0 7px;
            flex-shrink: 0;
        }

        .conversation-side {
            color: #8a8d91;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* CENTER CHAT */
        .chat-area {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }

        .chat-header {
            height: 76px;
            border-bottom: 1px solid #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
            flex-shrink: 0;
        }

        .chat-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .chat-user .avatar {
            width: 40px;
            height: 40px;
        }

        .chat-user-info h2 {
            font-size: 17px;
            font-weight: 700;
            margin: 4px 0;
            line-height: 23px;
            color: #080809;
        }

        .chat-user-info p {
            font-size: 13px;
            color: #65686c;
        }

        .chat-actions {
            display: flex;
            gap: 18px;
            align-items: center;
        }

        .chat-actions button {
            border: none;
            background: transparent;
            padding: 0;
            cursor: pointer;
        }

        .chat-actions i {
            color: #a000ff;
            font-size: 20px;
            cursor: pointer;
        }

        /* SCROLL 2 */
        .messages {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 12px 18px;
            background: #fff;
            min-height: 0;
        }

        .message-row {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            margin: 10px 0;
        }

        .message-row.search-hit .bubble {
            box-shadow: 0 0 0 2px #1877f2 inset;
        }

        .message-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #d8dadf;
            flex-shrink: 0;
            object-fit: cover;
        }

        .message-group {
            max-width: 60%;
            display: flex;
            flex-direction: column;
        }

        .message-body {
            display: flex;
            align-items: center;
            gap: 8px;
            max-width: calc(100% - 40px);
        }

        .sender-name {
            font-size: 14px;
            color: #65676b;
            margin: 0 0 6px 12px;
        }

        .bubble {
            background: #f0f2f5;
            padding: 12px 16px;
            border-radius: 20px;
            font-size: 15px;
            line-height: 1.33;
            color: #080809;
            width: fit-content;
            margin-bottom: 4px;
            max-width: 100%;
            word-break: break-word;
        }

        .attachment-image {
            max-width: 240px;
            border-radius: 14px;
            display: block;
        }

        .message-row.own {
            justify-content: flex-end;
        }

        .message-row.own .message-group {
            align-items: flex-end;
        }

        .message-row.own .message-body {
            flex-direction: row-reverse;
        }

        .message-row.own .sender-name {
            margin: 0 12px 6px 0;
            text-align: right;
        }

        .message-row.own .bubble {
            background: #1877f2;
            color: #fff;
        }

        .message-row.own .bubble a {
            color: #fff;
        }

        .mention {
            font-weight: 700;
            color: inherit;
        }

        .time-divider {
            text-align: center;
            color: #8a8d91;
            font-size: 14px;
            margin: 40px 0 20px;
        }

        .seen-icons {
            display: flex;
            justify-content: flex-end;
            gap: 4px;
            margin-top: 8px;
            padding-right: 8px;
        }

        .seen-icons img {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            object-fit: cover;
        }

        .reply-snippet {
            border-left: 3px solid #ccd0d5;
            padding: 6px 10px;
            margin: 0 0 6px 0;
            background: #f7f8fa;
            border-radius: 10px;
            font-size: 13px;
            color: #65676b;
            max-width: 100%;
        }

        .reply-snippet strong {
            color: #1c1e21;
            display: block;
            margin-bottom: 2px;
        }

        .message-inline-actions {
            display: flex;
            align-items: center;
            gap: 6px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.16s ease;
        }

        .message-row:hover .message-inline-actions {
            opacity: 1;
            pointer-events: auto;
        }

        .message-action-icon {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: none;
            background: #f0f2f5;
            color: #65676b;
            cursor: pointer;
            font-size: 14px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .message-action-icon:hover {
            background: #e4e6eb;
            color: #1c1e21;
        }

        .message-more-wrap {
            position: relative;
        }

        .message-more-menu {
            position: absolute;
            z-index: 8;
            bottom: calc(100% + 10px);
            left: 0;
            min-width: 132px;
            border-radius: 12px;
            background: #fff;
            border: 1px solid #e4e6eb;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.14);
            padding: 6px;
            display: none;
        }

        .message-more-menu.open {
            display: block;
        }

        .message-more-menu button {
            width: 100%;
            border: none;
            background: transparent;
            text-align: left;
            border-radius: 8px;
            padding: 9px 10px;
            cursor: pointer;
            font-size: 14px;
            color: #1c1e21;
        }

        .message-more-menu button:hover {
            background: #f2f3f5;
        }

        .message-hover-time {
            min-width: 54px;
            text-align: right;
            font-size: 12px;
            color: #65676b;
            opacity: 0;
            transition: opacity 0.16s ease;
            pointer-events: none;
        }

        .message-row:hover .message-hover-time {
            opacity: 1;
        }

        .message-pin {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-top: 2px;
            color: #65676b;
            font-size: 12px;
        }

        .reaction-row {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .reaction-chip {
            border-radius: 999px;
            background: #f0f2f5;
            color: #050505;
            font-size: 12px;
            padding: 2px 8px;
            border: 1px solid #d8dadf;
        }

        .reaction-chip.mine {
            border-color: #1877f2;
            background: #e7f3ff;
            color: #1877f2;
        }

        .typing-indicator {
            min-height: 22px;
            padding: 0 22px 6px;
            color: #65676b;
            font-size: 13px;
        }

        .reply-preview-bar,
        .edit-preview-bar,
        .attachment-preview-bar {
            margin: 0 16px;
            border: 1px solid #e4e6eb;
            background: #f7f8fa;
            border-radius: 10px;
            padding: 8px 10px;
            display: none;
        }

        .reply-preview-header,
        .attachment-preview-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 12px;
            color: #65676b;
            margin-bottom: 6px;
        }

        .reply-preview-content {
            font-size: 13px;
            color: #1c1e21;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .close-preview-btn {
            border: none;
            background: transparent;
            color: #65676b;
            cursor: pointer;
            font-size: 14px;
            padding: 0;
        }

        .attachment-preview-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
            max-height: 120px;
            overflow-y: auto;
        }

        .attachment-preview-item {
            font-size: 13px;
            color: #1c1e21;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-input-area {
            border-top: 1px solid #e4e6eb;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .left-tools,
        .right-tools {
            display: flex;
            align-items: center;
            gap: 14px;
            color: #1877f2;
            font-size: 20px;
            flex-shrink: 0;
        }

        .left-tools i,
        .right-tools i {
            cursor: pointer;
        }

        .gif-text {
            font-size: 16px;
            font-weight: 700;
            color: #1877f2;
            cursor: pointer;
        }

        .input-box {
            flex: 1;
            height: 44px;
            border-radius: 999px;
            background: #f0f2f5;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            color: #65676b;
            font-size: 16px;
        }

        .input-box .fa-face-smile {
            color: #1877f2;
            font-size: 20px;
        }

        /* RIGHT PANEL */
        .right-panel {
            border-left: 1px solid #e4e6eb;
            display: flex;
            flex-direction: column;
            padding: 18px 18px 0;
            overflow-y: auto;
        }

        .right-search-panel {
            display: none;
            flex-direction: column;
            gap: 14px;
            padding: 6px 0 16px;
            min-height: 100%;
        }

        .right-search-header {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 36px;
            font-weight: 700;
        }

        .right-search-header button {
            border: none;
            background: transparent;
            font-size: 24px;
            cursor: pointer;
            color: #1c1e21;
        }

        .right-search-box {
            border-radius: 999px;
            background: #f0f2f5;
            padding: 12px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #65676b;
        }

        .right-search-box input {
            border: none;
            background: transparent;
            outline: none;
            flex: 1;
            min-width: 0;
            font-size: 18px;
            color: #1c1e21;
        }

        .message-search-count {
            font-size: 14px;
            color: #65676b;
            white-space: nowrap;
            display: none;
        }

        .message-search-clear {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            color: #1c1e21;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .message-search-results {
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
            min-height: 0;
            padding-bottom: 8px;
        }

        .message-search-item {
            width: 100%;
            border: none;
            background: transparent;
            text-align: left;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .message-search-item:hover {
            background: #f2f3f5;
        }

        .message-search-avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            object-fit: cover;
            background: #d8dadf;
            flex-shrink: 0;
        }

        .message-search-meta {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .message-search-sender {
            font-size: 16px;
            font-weight: 700;
            color: #1c1e21;
        }

        .message-search-content-row {
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

        .message-search-content {
            font-size: 15px;
            color: #65676b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            min-width: 0;
        }

        .message-search-hit {
            background: #ffe08a;
            color: #1c1e21;
            border-radius: 4px;
            padding: 0 1px;
            font-weight: 700;
        }

        .message-search-time {
            font-size: 15px;
            color: #8a8d91;
            white-space: nowrap;
        }

        .message-search-empty {
            font-size: 14px;
            color: #65676b;
            padding: 8px 12px;
        }

        .profile-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 0 12px;
        }

        .profile-stack {
            position: relative;
            width: 90px;
            height: 72px;
            margin-bottom: 10px;
        }

        .profile-stack .avatar.main {
            width: 64px;
            height: 64px;
            position: absolute;
            left: 6px;
            bottom: 0;
            z-index: 2;
        }

        .profile-stack .avatar.sub {
            width: 54px;
            height: 54px;
            position: absolute;
            right: 0;
            top: 0;
            z-index: 1;
            background: #d8dadf;
        }

        .profile-stack.single {
            width: 64px;
            height: 64px;
        }

        .profile-stack.single .avatar.main {
            left: 0;
            bottom: 0;
        }

        .profile-stack.single .avatar.sub {
            display: none;
        }

        .profile-name {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .profile-actions {
            display: flex;
            gap: 34px;
            margin-bottom: 18px;
        }

        .profile-action {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            font-size: 15px;
            color: #1c1e21;
        }

        .profile-action .circle {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #050505;
        }

        .accordion {
            margin-top: 10px;
        }

        .accordion-item {
            padding: 16px 0;
        }

        .accordion-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            padding: 0 2px;
            color: #080809;
            line-height: 20px;
        }

        .accordion-header i {
            transition: transform 0.16s ease;
        }

        .accordion-header.expanded i {
            transform: rotate(180deg);
        }

        .accordion-body {
            padding: 14px 0 0 0;
        }

        .file-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            color: #1c1e21;
        }

        .file-icon {
            width: 24px;
            text-align: center;
            font-size: 20px;
            color: #050505;
        }

        .member-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 8px 0;
        }

        .member-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .member-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            background: #d8dadf;
            flex-shrink: 0;
        }

        .member-text {
            min-width: 0;
        }

        .member-text strong {
            display: block;
            font-size: 18px;
            font-weight: 700;
            color: #1c1e21;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .member-text span {
            display: block;
            margin-top: 2px;
            font-size: 13px;
            color: #65676b;
        }

        .member-more-btn {
            border: none;
            background: transparent;
            color: #1c1e21;
            cursor: pointer;
            font-size: 18px;
            padding: 4px;
            flex-shrink: 0;
        }

        .generic-modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.26);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 34;
            padding: 16px;
        }

        .generic-modal.open {
            display: flex;
        }

        .pinned-modal-overlay {
            background: rgba(0, 0, 0, 0.12);
            align-items: flex-start;
            justify-content: center;
            padding-top: 0;
            z-index: 40;
        }

        .pinned-modal-card {
            width: min(760px, 92vw);
            max-height: 82vh;
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 28px rgba(0, 0, 0, 0.16);
            display: flex;
            flex-direction: column;
        }

        .pinned-modal-header {
            position: relative;
            height: 82px;
            border-bottom: 1px solid #d9d9d9;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            background: #fff;
        }

        .pinned-modal-title {
            font-size: 17px;
            font-weight: 700;
            color: #111;
            line-height: 1.2;
        }

        .pinned-modal-close {
            position: absolute;
            top: 18px;
            right: 18px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            cursor: pointer;
        }

        .pinned-modal-close::before,
        .pinned-modal-close::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 22px;
            height: 3px;
            background: #606770;
            border-radius: 3px;
        }

        .pinned-modal-close::before {
            transform: translate(-50%, -50%) rotate(45deg);
        }

        .pinned-modal-close::after {
            transform: translate(-50%, -50%) rotate(-45deg);
        }

        .pinned-modal-body {
            flex: 1;
            overflow-y: auto;
            background: #fff;
            padding: 20px 20px 18px;
        }

        .generic-card {
            width: min(1120px, 96vw);
            max-height: 92vh;
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.22);
        }

        .generic-card.compact {
            width: min(560px, 92vw);
            max-height: 84vh;
        }

        .generic-header {
            height: 82px;
            border-bottom: 1px solid #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .generic-header h3 {
            font-size: 17px;
            font-weight: 700;
            color: #1c1e21;
        }

        .generic-close {
            position: absolute;
            right: 14px;
            top: 18px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            color: #61656a;
            font-size: 17px;
            cursor: pointer;
        }

        .generic-body {
            min-height: 220px;
            padding: 16px 18px 18px;
            overflow-y: auto;
        }

        .pinned-empty-state {
            min-height: 260px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #65676b;
            gap: 10px;
        }

        .pinned-empty-state i {
            font-size: 32px;
            color: #bcc0c4;
        }

        .pinned-empty-state strong {
            font-size: 17px;
            color: #4e5358;
        }

        .pinned-empty-state p {
            font-size: 15px;
        }

        .pinned-message-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .pinned-message-item {
            width: 100%;
            border: none;
            background: transparent;
            text-align: left;
            padding: 0;
            cursor: pointer;
        }

        .pinned-message-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-left: 56px;
            padding-right: 8px;
            margin-bottom: 6px;
        }

        .pinned-message-sender {
            font-size: 13px;
            color: #6b6f76;
            font-weight: 400;
        }

        .pinned-message-date {
            font-size: 13px;
            color: #6b6f76;
            font-weight: 400;
        }

        .pinned-message-row {
            display: flex;
            align-items: flex-end;
            gap: 10px;
        }

        .pinned-message-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            background: #d8dadf;
            flex-shrink: 0;
            margin-bottom: 2px;
        }

        .pinned-message-bubble-wrap {
            max-width: 100%;
            width: 100%;
        }

        .pinned-message-bubble {
            background: #f0f1f3;
            border-radius: 18px;
            padding: 12px 14px;
            min-height: 0;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            gap: 8px;
        }

        .pinned-message-link {
            font-size: 15px;
            line-height: 1.35;
            font-weight: 700;
            color: #111;
            text-decoration: underline;
            word-break: break-word;
            display: inline-block;
        }

        .pinned-message-domain {
            font-size: 15px;
            font-weight: 700;
            color: #111;
            line-height: 1.3;
        }

        .pinned-message-text {
            font-size: 15px;
            line-height: 1.4;
            color: #111;
            font-weight: 500;
            word-break: break-word;
        }

        .pinned-message-hint {
            font-size: 13px;
            color: #8b9098;
            margin-top: 8px;
            padding-left: 56px;
        }

        .rename-description {
            font-size: 15px;
            color: #1c1e21;
            margin-bottom: 10px;
        }

        .rename-input-wrap {
            border: 1px solid #c7cbd1;
            border-radius: 12px;
            padding: 10px 12px;
        }

        .rename-input-label {
            font-size: 13px;
            color: #6f7378;
            margin-bottom: 4px;
            display: block;
        }

        .rename-input-row {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 12px;
        }

        .rename-input-row input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 17px;
            font-weight: 500;
            color: #1c1e21;
            background: transparent;
        }

        .rename-count {
            font-size: 13px;
            color: #6f7378;
            flex-shrink: 0;
        }

        .rename-footer {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            margin-top: 12px;
        }

        .text-btn {
            border: none;
            background: transparent;
            color: #2a64c7;
            font-size: 17px;
            cursor: pointer;
            padding: 6px 8px;
        }

        .solid-btn {
            border: none;
            border-radius: 10px;
            background: #1877f2;
            color: #fff;
            font-size: 17px;
            font-weight: 700;
            padding: 8px 18px;
            cursor: pointer;
        }

        .solid-btn[disabled] {
            background: #d4d8de;
            color: #a4a9af;
            cursor: not-allowed;
        }

        .delete-confirm-card {
            width: min(420px, 92vw);
            max-height: 84vh;
            background: #fff;
            border-radius: 14px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.22);
        }

        .delete-confirm-header {
            height: 64px;
            border-bottom: 1px solid #e4e6eb;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 0 56px 0 16px;
        }

        .delete-confirm-header h3 {
            font-size: 17px;
            font-weight: 700;
            color: #1c1e21;
        }

        .delete-confirm-close {
            position: absolute;
            right: 12px;
            top: 12px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: #e4e6eb;
            color: #61656a;
            font-size: 17px;
            cursor: pointer;
        }

        .delete-confirm-body {
            padding: 16px;
        }

        .delete-confirm-body p {
            font-size: 15px;
            color: #1c1e21;
            line-height: 1.5;
            margin: 0;
        }

        .delete-confirm-actions {
            margin-top: 16px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
        }

        .danger-btn {
            border: none;
            border-radius: 10px;
            background: #d93025;
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            padding: 8px 16px;
            cursor: pointer;
        }

        .danger-btn[disabled] {
            background: #ef9a95;
            cursor: not-allowed;
        }

        /* SCROLLBAR STYLE */
        .chat-list::-webkit-scrollbar,
        .messages::-webkit-scrollbar,
        .right-panel::-webkit-scrollbar {
            width: 8px;
        }

        .chat-list::-webkit-scrollbar-track,
        .messages::-webkit-scrollbar-track,
        .right-panel::-webkit-scrollbar-track {
            background: transparent;
        }

        .chat-list::-webkit-scrollbar-thumb,
        .messages::-webkit-scrollbar-thumb,
        .right-panel::-webkit-scrollbar-thumb {
            background: #bcc0c4;
            border-radius: 999px;
        }

        .chat-list::-webkit-scrollbar-thumb:hover,
        .messages::-webkit-scrollbar-thumb:hover,
        .right-panel::-webkit-scrollbar-thumb:hover {
            background: #a8adb3;
        }

        .chat-list,
        .messages,
        .right-panel {
            scrollbar-width: thin;
            scrollbar-color: #bcc0c4 transparent;
        }

        @@media (max-width: 1400px) {
            .app {
                grid-template-columns: 360px 1fr 340px;
            }

            .app.right-panel-collapsed {
                grid-template-columns: 360px 1fr 0;
            }
        }

        @@media (max-width: 1200px) {
            .app {
                grid-template-columns: 340px 1fr;
            }

            .app.right-panel-collapsed {
                grid-template-columns: 340px 1fr;
            }

            .right-panel {
                display: none;
            }
        }

        @@media (max-width: 768px) {
            .app {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }

            .message-group {
                max-width: 80%;
            }

            .pinned-modal-card {
                width: calc(100vw - 16px);
                height: calc(100vh - 16px);
                border-radius: 16px;
            }

            .pinned-modal-header {
                height: 88px;
            }

            .pinned-modal-close {
                width: 40px;
                height: 40px;
                right: 16px;
                top: 14px;
            }

            .pinned-modal-close::before,
            .pinned-modal-close::after {
                width: 20px;
            }

            .pinned-modal-body {
                padding: 16px 14px;
            }

            .pinned-message-meta {
                padding-left: 0;
                padding-right: 0;
            }

            .pinned-message-row {
                gap: 12px;
                align-items: flex-start;
            }

            .pinned-message-avatar {
                width: 34px;
                height: 34px;
            }

            .pinned-message-bubble-wrap {
                max-width: 100%;
            }

            .pinned-message-bubble {
                min-height: auto;
                padding: 10px 12px;
                border-radius: 14px;
            }

            .pinned-message-hint {
                padding-left: 0;
            }
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_GlobalNavigationBar")
    <div class="app" id="appLayout">
        <!-- LEFT -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h1>Đoạn chat</h1>
                <div class="header-actions">
                    <button class="icon-btn"><i class="fa-solid fa-ellipsis"></i></button>
                    <button class="icon-btn" id="openCreateGroupButton" type="button" title="Tạo nhóm chat">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                </div>
            </div>

            <div class="search-box" id="conversationSearchForm">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input name="q"
                       id="conversationSearchInput"
                       value="@Model.Keyword"
                       placeholder="Tìm kiếm trên Messenger"
                       style="border:none;background:transparent;outline:none;width:100%;font-size:15px;color:#050505;" />
            </div>
            <div id="userSearchResults" style="padding: 0 8px 10px; max-height: 220px; overflow-y: auto; display:none;">
                <div style="font-size: 13px; color: #65676b; margin-bottom: 8px;">Kết quả người dùng</div>
                <div id="userSearchResultsContent"></div>
            </div>

            <div class="tabs">
                <a class="tab @(activeTab == "all" ? "active" : "")"
                   style="text-decoration:none;"
                   href="@Url.Action("Index", "Conversation", new { tab = "all" })">Tất cả</a>
                <a class="tab @(activeTab == "unread" ? "active" : "")"
                   style="text-decoration:none;"
                   href="@Url.Action("Index", "Conversation", new { tab = "unread" })">Chưa đọc</a>
                <a class="tab @(activeTab == "group" ? "active" : "")"
                   style="text-decoration:none;"
                   href="@Url.Action("Index", "Conversation", new { tab = "group" })">Nhóm</a>
            </div>

            <div class="chat-list" id="conversationList">
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="conversation-preview" style="padding: 8px 10px; color: #c62828;">@Model.ErrorMessage</div>
                }
                @foreach (var conversation in Model.Conversations)
                {
                    var isActive = Model.SelectedConversationId == conversation.Id;
                    var isUnread = conversation.HasUnread && !isActive;
                    var previewPrefix = conversation.LastSenderId.HasValue
                        ? (conversation.LastSenderId.Value == currentUserId
                            ? "Bạn: "
                            : $"{conversation.LastSenderName}: ")
                        : string.Empty;
                    var previewText = string.IsNullOrWhiteSpace(conversation.LastMessage)
                        ? "(Chưa có tin nhắn)"
                        : $"{previewPrefix}{conversation.LastMessage}";
                    <div class="conversation-list-item @(isActive ? "active" : "")" data-conversation-id="@conversation.Id">
                        <a class="conversation-item-link"
                           href="@Url.Action("Index", "Conversation", new { conversationId = conversation.Id, tab = Model.Tab })">
                            <div class="avatar-wrap">
                                <img class="avatar" src="@(string.IsNullOrWhiteSpace(conversation.AvatarUrl) ? "https://via.placeholder.com/56" : conversation.AvatarUrl)" alt="avatar" />
                            </div>
                            <div class="conversation-content">
                                <div class="conversation-name">@conversation.Name</div>
                                <div class="conversation-preview @(isUnread ? "unread" : "")">@previewText</div>
                            </div>
                        </a>
                        <div class="conversation-trailing">
                            @if (isUnread)
                            {
                                <div class="unread-badge">@conversation.UnreadCount</div>
                            }
                            <div class="conversation-actions">
                                <button type="button"
                                        class="conversation-more-btn"
                                        data-action="toggle-conversation-menu"
                                        data-conversation-id="@conversation.Id"
                                        aria-label="Tùy chọn đoạn chat">
                                    <i class="fa-solid fa-ellipsis"></i>
                                </button>
                                <div class="conversation-more-menu" data-conversation-menu="@conversation.Id">
                                    <button type="button"
                                            class="conversation-menu-item danger"
                                            data-action="delete-conversation"
                                            data-conversation-id="@conversation.Id">
                                        Xóa đoạn chat
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </aside>

        <!-- CENTER -->
        <main class="chat-area">
            <div class="chat-header">
                <div class="chat-user">
                    <img class="avatar" id="chatHeaderAvatar" src="@(string.IsNullOrWhiteSpace(selectedConversationAvatar) ? "https://via.placeholder.com/40" : selectedConversationAvatar)" alt="avatar" />
                    <div class="chat-user-info">
                        <h2 id="chatHeaderName">@selectedConversationName</h2>
                        <p id="chatHeaderSubtitle" style="@(isGroupConversation ? "" : "display:none;")">@(selectedMembers.Count) thành viên</p>
                    </div>
                </div>
                <div class="chat-actions">
                    <i class="fa-solid fa-phone"></i>
                    <i class="fa-solid fa-video"></i>
                    <button type="button" id="toggleRightPanelButton" style="border:none;background:transparent;padding:0;">
                        <i class="fa-solid fa-circle-info"></i>
                    </button>
                </div>
            </div>

            <div class="messages"
                 id="messagesPanel"
                 data-conversation-id="@(Model.SelectedConversationId ?? 0)"
                 data-current-user-id="@currentUserId"
                 data-last-message-id="@lastMessageId">
                @if (Model.Messages.Count == 0)
                {
                    <div class="time-divider">Chưa có tin nhắn</div>
                }
                else
                {
                    foreach (var message in Model.Messages)
                    {
                        var isMine = message.SenderId == currentUserId;
                        <div class="message-row @(isMine ? "own" : "")" data-message-id="@message.Id">
                            @if (!isMine)
                            {
                                <img class="message-avatar"
                                     src="@(string.IsNullOrWhiteSpace(message.SenderAvatarUrl) ? "https://via.placeholder.com/32" : message.SenderAvatarUrl)"
                                     alt="avatar" />
                            }
                            <div class="message-group">
                                @if (!isMine && isGroupConversation)
                                {
                                    <div class="sender-name">@message.SenderName</div>
                                }
                                <div class="bubble">@message.Content</div>
                                @foreach (var attachment in message.Attachments)
                                {
                                    <div class="bubble">
                                        <a href="@attachment.FileUrl" target="_blank" rel="noopener noreferrer">@attachment.FileName</a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <div id="typingIndicator" class="typing-indicator"></div>
            <div id="replyPreview" class="reply-preview-bar"></div>
            <div id="editPreview" class="edit-preview-bar"></div>
            <div id="attachmentPreview" class="attachment-preview-bar"></div>

            <div class="chat-input-area">
                <div class="left-tools">
                    <i class="fa-solid fa-circle-plus"></i>
                    <i class="fa-solid fa-image" id="pickFilesButton" title="Gửi file"></i>
                    <i class="fa-regular fa-face-laugh"></i>
                    <span class="gif-text">GIF</span>
                </div>
                <form id="sendMessageForm"
                      method="post"
                      enctype="multipart/form-data"
                      asp-controller="Conversation"
                      asp-action="SendMessage"
                      style="display:flex;flex:1;gap:8px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="conversationId" value="@Model.SelectedConversationId" />
                    <input type="hidden" name="tab" value="@Model.Tab" />
                    <input type="hidden" id="replyToMessageIdInput" name="replyToMessageId" />
                    <input type="file" id="attachmentInput" name="attachments" multiple style="display:none;" />
                    <div class="input-box">
                        <input id="messageInput"
                               name="content"
                               autocomplete="off"
                               placeholder="Aa"
                               style="width:100%;border:none;background:transparent;outline:none;" />
                        <i class="fa-regular fa-face-smile"></i>
                    </div>
                    <button class="icon-btn"
                            id="sendButton"
                            type="submit"
                            @(Model.SelectedConversationId is null ? "disabled" : "")>
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </form>

                <div class="right-tools">
                    <i class="fa-solid fa-thumbs-up"></i>
                </div>
            </div>
        </main>

        <!-- RIGHT -->
        <aside class="right-panel">
            <div id="rightInfoPanel">
                <div class="profile-box">
                    <div class="profile-stack @((!isGroupConversation || hasCustomGroupAvatar) ? "single" : "")" id="rightProfileStack">
                        <img class="avatar main" id="rightProfileAvatar" src="@(string.IsNullOrWhiteSpace(selectedConversationAvatar) ? "https://via.placeholder.com/64" : selectedConversationAvatar)" alt="avatar" />
                        <img class="avatar sub" id="rightProfileSubAvatar" src="https://via.placeholder.com/54" alt="avatar" />
                    </div>
                    <div class="profile-name" id="rightProfileName">@selectedConversationName</div>

                    <div class="profile-actions">
                        <div class="profile-action">
                            <div class="circle"><i class="fa-solid fa-bell-slash"></i></div>
                            <span>Bật lại</span>
                        </div>
                        <button class="profile-action" id="openMessageSearchButton" type="button" style="border:none;background:transparent;">
                            <div class="circle"><i class="fa-solid fa-magnifying-glass"></i></div>
                            <span>Tìm kiếm</span>
                        </button>
                    </div>
                </div>

                <div class="accordion">
                    <div class="accordion-item">
                        <div class="accordion-header" data-action="toggle-accordion" data-target="chatInfoBody">
                            <span>Thông tin về đoạn chat</span>
                            <i class="fa-solid fa-chevron-down" id="chatInfoChevron"></i>
                        </div>
                        <div class="accordion-body" id="chatInfoBody" style="display:none;">
                            <button type="button" class="file-link" id="openPinnedMessagesButton" style="border:none;background:transparent;width:100%;text-align:left;">
                                <span class="file-icon"><i class="fa-solid fa-thumbtack"></i></span>
                                <span>Xem tin nhắn đã ghim</span>
                            </button>
                        </div>
                    </div>

                    <div class="accordion-item" id="chatCustomizeItem" style="@(isGroupConversation ? "" : "display:none;")">
                        <div class="accordion-header" data-action="toggle-accordion" data-target="chatCustomizeBody">
                            <span>Tùy chỉnh đoạn chat</span>
                            <i class="fa-solid fa-chevron-down" id="chatCustomizeChevron"></i>
                        </div>
                        <div class="accordion-body" id="chatCustomizeBody" style="display:none;">
                            <button type="button" class="file-link" id="openRenameConversationButton" style="border:none;background:transparent;width:100%;text-align:left;">
                                <span class="file-icon"><i class="fa-solid fa-pen"></i></span>
                                <span>Đổi tên đoạn chat</span>
                            </button>
                            <button type="button" class="file-link" id="changeConversationImageButton" style="border:none;background:transparent;width:100%;text-align:left;">
                                <span class="file-icon"><i class="fa-regular fa-image"></i></span>
                                <span>Thay đổi ảnh</span>
                            </button>
                            <input type="file" id="conversationImageInput" accept="image/*" style="display:none;" />
                        </div>
                    </div>

                    <div class="accordion-item" id="chatMembersItem" style="@(isGroupConversation ? "" : "display:none;")">
                        <div class="accordion-header" data-action="toggle-accordion" data-target="chatMembersBody">
                            <span>Thành viên trong đoạn chat</span>
                            <i class="fa-solid fa-chevron-down" id="chatMembersChevron"></i>
                        </div>
                        <div class="accordion-body" id="chatMembersBody" style="display:none;">
                            <div id="chatMembersList">
                                @if (selectedMembers.Count == 0)
                                {
                                    <div class="file-link"><span>Chưa có thành viên</span></div>
                                }
                                else
                                {
                                    foreach (var member in selectedMembers)
                                    {
                                        <div class="member-row">
                                            <div class="member-meta">
                                                <img src="@(string.IsNullOrWhiteSpace(member.AvatarUrl) ? "https://via.placeholder.com/44" : member.AvatarUrl)" class="member-avatar" alt="avatar" />
                                                <div class="member-text">
                                                    <strong>@member.FullName</strong>
                                                    <span>Thành viên</span>
                                                </div>
                                            </div>
                                            <button type="button" class="member-more-btn" title="Tùy chọn">
                                                <i class="fa-solid fa-ellipsis"></i>
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                            <button type="button" class="file-link" id="openAddMemberButton" style="border:none;background:transparent;width:100%;text-align:left;">
                                <span class="file-icon"><i class="fa-solid fa-user-plus"></i></span>
                                <span>Thêm người</span>
                            </button>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <div class="accordion-header">
                            <span>File phương tiện, file và liên kết</span>
                            <i class="fa-solid fa-chevron-up"></i>
                        </div>
                        <div class="accordion-body">
                            <div class="file-link">
                                <span class="file-icon"><i class="fa-regular fa-image"></i></span>
                                <span>File phương tiện</span>
                            </div>
                            <div class="file-link">
                                <span class="file-icon"><i class="fa-regular fa-file-lines"></i></span>
                                <span>File</span>
                            </div>
                            <div class="file-link">
                                <span class="file-icon"><i class="fa-solid fa-link"></i></span>
                                <span>Liên kết</span>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <div class="accordion-header">
                            <span>Quyền riêng tư và hỗ trợ</span>
                            <i class="fa-solid fa-chevron-down"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="right-search-panel" id="rightSearchPanel">
                <div class="right-search-header">
                    <button type="button" id="closeMessageSearchButton"><i class="fa-solid fa-xmark"></i></button>
                    <span>Tìm kiếm</span>
                </div>
                <div class="right-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input id="messageSearchInput" placeholder="Tìm kiếm trong cuộc trò chuyện" autocomplete="off" />
                    <span id="messageSearchCount" class="message-search-count"></span>
                    <button type="button" id="clearMessageSearchButton" class="message-search-clear" title="Xóa tìm kiếm">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="message-search-results" id="messageSearchResults">
                    <div class="message-search-empty">Nhập nội dung để tìm lịch sử tin nhắn.</div>
                </div>
            </div>
        </aside>
    </div>

    <div class="create-group-modal" id="createGroupModal" aria-hidden="true">
        <div class="create-group-card">
            <div class="create-group-header">
                <h3>Tạo nhóm chat</h3>
                <button class="icon-btn" type="button" id="closeCreateGroupModalButton">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="create-group-body">
                <input id="createGroupNameInput" class="create-group-name" placeholder="Tên nhóm (tùy chọn)" maxlength="80" />
                <div class="create-group-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input id="createGroupSearchInput" placeholder="Tìm kiếm người để thêm vào nhóm" autocomplete="off" />
                </div>
                <div id="selectedGroupMembers" class="selected-member-list">
                    <div class="create-group-empty">Chưa chọn thành viên.</div>
                </div>
                <div id="createGroupUserResults" class="create-group-results">
                    <div class="create-group-empty">Nhập từ khóa để tìm người dùng.</div>
                </div>
            </div>
            <div class="create-group-footer">
                <button type="button" class="create-group-btn secondary" id="cancelCreateGroupButton">Hủy</button>
                <button type="button" class="create-group-btn primary" id="submitCreateGroupButton">Tạo nhóm</button>
            </div>
        </div>
    </div>

    <div class="generic-modal pinned-modal-overlay" id="pinnedMessagesModal" aria-hidden="true">
        <div class="pinned-modal-card">
            <div class="pinned-modal-header">
                <div class="pinned-modal-title">Tin nhắn đã ghim</div>
                <button type="button" class="pinned-modal-close" id="closePinnedMessagesModalButton" aria-label="Đóng modal"></button>
            </div>
            <div class="pinned-modal-body" id="pinnedMessagesModalBody">
                <div class="pinned-empty-state">
                    <i class="fa-solid fa-thumbtack"></i>
                    <strong>Chưa ghim tin nhắn nào</strong>
                    <p>Tin nhắn đã ghim trong đoạn chat này sẽ hiển thị ở đây</p>
                </div>
            </div>
        </div>
    </div>

    <div class="generic-modal" id="renameConversationModal" aria-hidden="true">
        <div class="generic-card compact">
            <div class="generic-header">
                <h3>Đổi tên đoạn chat</h3>
                <button type="button" class="generic-close" id="closeRenameConversationModalButton"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="generic-body">
                <p class="rename-description">Mọi người đều biết khi tên nhóm chat thay đổi.</p>
                <div class="rename-input-wrap">
                    <span class="rename-input-label">Tên đoạn chat</span>
                    <div class="rename-input-row">
                        <input id="renameConversationInput" maxlength="500" />
                        <span class="rename-count" id="renameConversationCount">0/500</span>
                    </div>
                </div>
                <div class="rename-footer">
                    <button type="button" class="text-btn" id="cancelRenameConversationButton">Hủy</button>
                    <button type="button" class="solid-btn" id="saveRenameConversationButton">Lưu</button>
                </div>
            </div>
        </div>
    </div>

    <div class="create-group-modal" id="addMemberModal" aria-hidden="true">
        <div class="create-group-card">
            <div class="create-group-header">
                <h3>Thêm thành viên</h3>
                <button class="icon-btn" type="button" id="closeAddMemberModalButton">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="create-group-body">
                <div class="create-group-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input id="addMemberSearchInput" placeholder="Tìm kiếm người để thêm vào nhóm" autocomplete="off" />
                </div>
                <div id="selectedAddMembers" class="selected-member-list">
                    <div class="create-group-empty">Chưa chọn thành viên.</div>
                </div>
                <div id="addMemberResults" class="create-group-results">
                    <div class="create-group-empty">Nhập từ khóa để tìm người dùng.</div>
                </div>
            </div>
            <div class="create-group-footer">
                <button type="button" class="create-group-btn secondary" id="cancelAddMemberButton">Hủy</button>
                <button type="button" class="create-group-btn primary" id="submitAddMemberButton">Thêm người</button>
            </div>
        </div>
    </div>

    <div class="generic-modal" id="deleteConversationConfirmModal" aria-hidden="true">
        <div class="delete-confirm-card">
            <div class="delete-confirm-header">
                <h3>Xóa đoạn chat</h3>
                <button type="button" class="delete-confirm-close" id="closeDeleteConversationConfirmButton" aria-label="Đóng">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="delete-confirm-body">
                <p>Bạn có chắc muốn xóa đoạn chat này ở cả 2 phía? Hành động này không thể hoàn tác.</p>
                <div class="delete-confirm-actions">
                    <button type="button" class="text-btn" id="cancelDeleteConversationConfirmButton">Hủy</button>
                    <button type="button" class="danger-btn" id="confirmDeleteConversationButton">Xóa đoạn chat</button>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/global-navbar.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/%40microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            var appLayout = document.getElementById("appLayout");
            var shouldScroll = @Model.ShouldScrollToBottom.ToString().ToLowerInvariant();
            var panel = document.getElementById("messagesPanel");
            var conversationList = document.getElementById("conversationList");
            var userSearchResultsPanel = document.getElementById("userSearchResults");
            var userSearchResultsContent = document.getElementById("userSearchResultsContent");
            var typingIndicator = document.getElementById("typingIndicator");
            var replyPreview = document.getElementById("replyPreview");
            var editPreview = document.getElementById("editPreview");
            var attachmentPreview = document.getElementById("attachmentPreview");
            var rightInfoPanel = document.getElementById("rightInfoPanel");
            var rightSearchPanel = document.getElementById("rightSearchPanel");
            var openMessageSearchButton = document.getElementById("openMessageSearchButton");
            var closeMessageSearchButton = document.getElementById("closeMessageSearchButton");
            var messageSearchInput = document.getElementById("messageSearchInput");
            var messageSearchCount = document.getElementById("messageSearchCount");
            var messageSearchResults = document.getElementById("messageSearchResults");
            var clearMessageSearchButton = document.getElementById("clearMessageSearchButton");
            var rightPanel = document.querySelector(".right-panel");
            var toggleRightPanelButton = document.getElementById("toggleRightPanelButton");
            var chatHeaderName = document.getElementById("chatHeaderName");
            var chatHeaderSubtitle = document.getElementById("chatHeaderSubtitle");
            var chatHeaderAvatar = document.getElementById("chatHeaderAvatar");
            var rightProfileName = document.getElementById("rightProfileName");
            var rightProfileAvatar = document.getElementById("rightProfileAvatar");
            var rightProfileStack = document.getElementById("rightProfileStack");
            var rightProfileSubAvatar = document.getElementById("rightProfileSubAvatar");
            var chatCustomizeItem = document.getElementById("chatCustomizeItem");
            var chatMembersItem = document.getElementById("chatMembersItem");
            var chatMembersList = document.getElementById("chatMembersList");
            var openPinnedMessagesButton = document.getElementById("openPinnedMessagesButton");
            var pinnedMessagesModal = document.getElementById("pinnedMessagesModal");
            var closePinnedMessagesModalButton = document.getElementById("closePinnedMessagesModalButton");
            var pinnedMessagesModalBody = document.getElementById("pinnedMessagesModalBody");
            var openRenameConversationButton = document.getElementById("openRenameConversationButton");
            var renameConversationModal = document.getElementById("renameConversationModal");
            var closeRenameConversationModalButton = document.getElementById("closeRenameConversationModalButton");
            var cancelRenameConversationButton = document.getElementById("cancelRenameConversationButton");
            var saveRenameConversationButton = document.getElementById("saveRenameConversationButton");
            var renameConversationInput = document.getElementById("renameConversationInput");
            var renameConversationCount = document.getElementById("renameConversationCount");
            var changeConversationImageButton = document.getElementById("changeConversationImageButton");
            var conversationImageInput = document.getElementById("conversationImageInput");
            var openAddMemberButton = document.getElementById("openAddMemberButton");
            var addMemberModal = document.getElementById("addMemberModal");
            var closeAddMemberModalButton = document.getElementById("closeAddMemberModalButton");
            var cancelAddMemberButton = document.getElementById("cancelAddMemberButton");
            var addMemberSearchInput = document.getElementById("addMemberSearchInput");
            var selectedAddMembers = document.getElementById("selectedAddMembers");
            var addMemberResults = document.getElementById("addMemberResults");
            var submitAddMemberButton = document.getElementById("submitAddMemberButton");
            var deleteConversationConfirmModal = document.getElementById("deleteConversationConfirmModal");
            var closeDeleteConversationConfirmButton = document.getElementById("closeDeleteConversationConfirmButton");
            var cancelDeleteConversationConfirmButton = document.getElementById("cancelDeleteConversationConfirmButton");
            var confirmDeleteConversationButton = document.getElementById("confirmDeleteConversationButton");
            var openCreateGroupButton = document.getElementById("openCreateGroupButton");
            var createGroupModal = document.getElementById("createGroupModal");
            var closeCreateGroupModalButton = document.getElementById("closeCreateGroupModalButton");
            var cancelCreateGroupButton = document.getElementById("cancelCreateGroupButton");
            var createGroupNameInput = document.getElementById("createGroupNameInput");
            var createGroupSearchInput = document.getElementById("createGroupSearchInput");
            var selectedGroupMembers = document.getElementById("selectedGroupMembers");
            var createGroupUserResults = document.getElementById("createGroupUserResults");
            var submitCreateGroupButton = document.getElementById("submitCreateGroupButton");
            var conversationId = Number((panel && panel.dataset.conversationId) || 0);
            var currentUserId = Number((panel && panel.dataset.currentUserId) || 0);
            var isGroupConversation = @Html.Raw(JsonSerializer.Serialize(isGroupConversation));
            var currentConversationMembers = @Html.Raw(JsonSerializer.Serialize(selectedMembers));
            var currentTab = @Html.Raw(JsonSerializer.Serialize(activeTab));
            var realtimeToken = @Html.Raw(JsonSerializer.Serialize(Model.RealtimeToken ?? string.Empty));
            var chatHubUrl = @Html.Raw(JsonSerializer.Serialize(Model.ChatHubUrl ?? string.Empty));
            var sendForm = document.getElementById("sendMessageForm");
            var sendButton = document.getElementById("sendButton");
            var messageInput = document.getElementById("messageInput");
            var conversationIdInput = sendForm ? sendForm.querySelector('input[name="conversationId"]') : null;
            var replyToInput = document.getElementById("replyToMessageIdInput");
            var attachmentInput = document.getElementById("attachmentInput");
            var pickFilesButton = document.getElementById("pickFilesButton");
            var antiForgeryInput = sendForm ? sendForm.querySelector('input[name="__RequestVerificationToken"]') : null;
            var antiForgeryToken = antiForgeryInput ? antiForgeryInput.value : "";
            var pollTimer = null;
            var connection = null;
            var allMessages = [];
            var selectedReplyMessage = null;
            var selectedEditMessage = null;
            var typingUsers = {};
            var typingStopTimer = null;
            var hasSentTyping = false;
            var searchRequestSequence = 0;
            var latestPageSnapshot = "";
            var loadedPage = 1;
            var hasMorePages = true;
            var isLoadingOlder = false;
            var pageSize = 30;
            var messageSearchRequestSequence = 0;
            var pinnedMessageIds = {};
            var pollTick = 0;
            var realtimeSyncTimer = null;
            var conversationRefreshTimer = null;
            var isRightPanelVisible = true;
            var createGroupSearchSequence = 0;
            var selectedGroupMemberMap = {};
            var addMemberSearchSequence = 0;
            var selectedAddMemberMap = {};
            var currentConversationName = @Html.Raw(JsonSerializer.Serialize(selectedConversationName));
            var currentConversationAvatar = @Html.Raw(JsonSerializer.Serialize(string.IsNullOrWhiteSpace(selectedConversationAvatar) ? "https://via.placeholder.com/64" : selectedConversationAvatar));
            var currentConversationHasCustomAvatar = @Html.Raw(JsonSerializer.Serialize(hasCustomGroupAvatar));
            var isDeletingConversation = false;
            var pendingDeleteConversationId = 0;
            var isSwitchingConversation = false;

            function scrollToBottom() {
                if (!panel) return;
                panel.scrollTop = panel.scrollHeight;
            }

            function startPolling() {
                if (!conversationId || pollTimer) return;
                loadLatestMessages(false, false);
                refreshConversationList();
                pollTimer = setInterval(function () {
                    pollTick += 1;
                    loadLatestMessages(false, false);
                    if (pollTick % 2 === 0) {
                        refreshConversationList();
                    }
                }, 1500);
            }

            function stopPolling() {
                if (!pollTimer) return;
                clearInterval(pollTimer);
                pollTimer = null;
                pollTick = 0;
            }

            function scheduleRealtimeSync(forceRender) {
                if (realtimeSyncTimer) {
                    clearTimeout(realtimeSyncTimer);
                }

                realtimeSyncTimer = setTimeout(function () {
                    realtimeSyncTimer = null;
                    loadLatestMessages(false, Boolean(forceRender));
                }, 220);
            }

            function scheduleConversationListRefresh(delayMs) {
                var delay = typeof delayMs === "number" ? delayMs : 120;
                if (conversationRefreshTimer) {
                    clearTimeout(conversationRefreshTimer);
                }

                conversationRefreshTimer = setTimeout(function () {
                    conversationRefreshTimer = null;
                    refreshConversationList();
                }, delay);
            }

            function setRightPanelVisible(visible) {
                if (!appLayout || !rightPanel) return;
                if (window.matchMedia("(max-width: 1200px)").matches) return;

                isRightPanelVisible = Boolean(visible);
                appLayout.classList.toggle("right-panel-collapsed", !isRightPanelVisible);
            }

            function updateCreateGroupSubmitState() {
                if (!submitCreateGroupButton) return;
                submitCreateGroupButton.disabled = Object.keys(selectedGroupMemberMap).length === 0;
            }

            function resetCreateGroupState() {
                selectedGroupMemberMap = {};
                createGroupSearchSequence = 0;

                if (createGroupNameInput) {
                    createGroupNameInput.value = "";
                }

                if (createGroupSearchInput) {
                    createGroupSearchInput.value = "";
                }

                if (createGroupUserResults) {
                    createGroupUserResults.innerHTML = '<div class="create-group-empty">Nhập từ khóa để tìm người dùng.</div>';
                }

                renderSelectedGroupMembers();
                updateCreateGroupSubmitState();
            }

            function renderSelectedGroupMembers() {
                if (!selectedGroupMembers) return;

                var memberIds = Object.keys(selectedGroupMemberMap);
                if (memberIds.length === 0) {
                    selectedGroupMembers.innerHTML = '<div class="create-group-empty">Chưa chọn thành viên.</div>';
                    return;
                }

                var html = "";
                memberIds.forEach(function (key) {
                    var member = selectedGroupMemberMap[key];
                    if (!member) return;

                    html += '<div class="selected-member-chip">';
                    html += '<span>' + escapeHtml(member.fullName || "") + "</span>";
                    html += '<button type="button" data-action="remove-selected-member" data-user-id="' + Number(member.userId || 0) + '"><i class="fa-solid fa-xmark"></i></button>';
                    html += "</div>";
                });

                selectedGroupMembers.innerHTML = html || '<div class="create-group-empty">Chưa chọn thành viên.</div>';
            }

            function renderCreateGroupUsers(users) {
                if (!createGroupUserResults) return;

                if (!Array.isArray(users) || users.length === 0) {
                    createGroupUserResults.innerHTML = '<div class="create-group-empty">Không tìm thấy người dùng phù hợp.</div>';
                    return;
                }

                var html = "";
                users.forEach(function (user) {
                    var userId = Number(user.userId || 0);
                    if (!userId || userId === currentUserId) return;

