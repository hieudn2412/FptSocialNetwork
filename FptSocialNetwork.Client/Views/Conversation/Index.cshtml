                    window.alert("Hãy chọn một đoạn chat trước khi đổi ảnh.");
                    return false;
                }

                if (!file) return false;
                if (!String(file.type || "").toLowerCase().startsWith("image/")) {
                    window.alert("Vui lòng chọn file ảnh hợp lệ.");
                    return false;
                }

                var body = new FormData();
                if (antiForgeryToken) {
                    body.append("__RequestVerificationToken", antiForgeryToken);
                }
                body.append("conversationId", String(conversationId));
                body.append("image", file);

                if (changeConversationImageButton) {
                    changeConversationImageButton.disabled = true;
                }

                try {
                    var response = await fetch("/conversations/update-image-json", {
                        method: "POST",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: body,
                        credentials: "same-origin"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return false;
                    }

                    if (!response.ok) {
                        var errorMessage = await readResponseError(response, "Không thể cập nhật ảnh đoạn chat.");
                        window.alert(errorMessage);
                        return false;
                    }

                    var data = await response.json();
                    if (!data) return false;
                    setConversationDisplay(data.name || currentConversationName, data.avatarUrl || currentConversationAvatar);
                    scheduleConversationListRefresh(40);
                    return true;
                } catch {
                    window.alert("Không thể tải ảnh lên lúc này. Vui lòng thử lại.");
