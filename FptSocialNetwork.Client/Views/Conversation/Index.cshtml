            async function submitCreateGroup() {
                if (!submitCreateGroupButton) return;

                var ids = Object.keys(selectedGroupMemberMap).map(function (key) {
                    return Number(key);
                }).filter(function (id) {
                    return id > 0 && id !== currentUserId;
                });

                if (ids.length === 0) {
                    return;
                }

                submitCreateGroupButton.disabled = true;
                try {
                    var body = getRequestTokenParams();
                    var groupName = createGroupNameInput ? createGroupNameInput.value.trim() : "";
                    if (groupName) {
                        body.append("name", groupName);
                    }

                    ids.forEach(function (id) {
                        body.append("memberUserIds", String(id));
                    });

                    var response = await fetch("/conversations/create-group-json", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: body.toString(),
                        credentials: "same-origin"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) {
                        return;
                    }

                    var payload = await response.json();
                    var createdConversationId = Number((payload && payload.conversationId) || 0);
                    if (!createdConversationId) return;

                    window.location.href = buildConversationHref(createdConversationId);
                } finally {
                    submitCreateGroupButton.disabled = false;
                    updateCreateGroupSubmitState();
