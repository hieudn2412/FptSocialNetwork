            async function searchUsersForCreateGroup(keyword) {
                if (!createGroupUserResults) return;

                var trimmed = (keyword || "").trim();
                if (!trimmed) {
                    createGroupUserResults.innerHTML = '<div class="create-group-empty">Nhập từ khóa để tìm người dùng.</div>';
                    return;
                }

                var requestId = ++createGroupSearchSequence;
                createGroupUserResults.innerHTML = '<div class="create-group-empty">Đang tìm kiếm...</div>';
                try {
                    var response = await fetch("/conversations/users-search-json?q=" + encodeURIComponent(trimmed), {
                        method: "GET",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        cache: "no-store"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    var users = await response.json();
                    if (requestId !== createGroupSearchSequence) return;
                    renderCreateGroupUsers(users);
                } catch {
                    // Ignore transient group-search errors.
                }
            }

            function openCreateGroupModal() {
                if (!createGroupModal) return;
                resetCreateGroupState();
                createGroupModal.classList.add("open");
                createGroupModal.setAttribute("aria-hidden", "false");
