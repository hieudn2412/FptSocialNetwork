            function applyConversationDetail(detail) {
                if (!detail) return;

                var conversationType = String(detail.type || detail.Type || "").toLowerCase();
                isGroupConversation = conversationType === "group";
                currentConversationMembers = normalizeMemberList(detail.members || detail.Members || []);
                currentConversationHasCustomAvatar = isGroupConversation && String(detail.avatarUrl || detail.AvatarUrl || "").indexOf("via.placeholder.com") === -1;

                setConversationDisplay(detail.name || detail.Name || "", detail.avatarUrl || detail.AvatarUrl || "");
