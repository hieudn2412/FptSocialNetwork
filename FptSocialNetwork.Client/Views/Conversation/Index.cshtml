                if (isGroupConversation) {
                    var avatarTrimmed = currentConversationAvatar.trim();
                    currentConversationHasCustomAvatar =
                        avatarTrimmed.length > 0 &&
                        avatarTrimmed.indexOf("via.placeholder.com") === -1;
                }

