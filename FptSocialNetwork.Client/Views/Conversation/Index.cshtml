            function renderPinnedMessagesModal() {
                if (!pinnedMessagesModalBody) return;

                var pinnedIds = Object.keys(pinnedMessageIds).map(function (key) {
                    return Number(key);
                }).filter(function (id) {
                    return id > 0;
                });

                if (pinnedIds.length === 0) {
                    pinnedMessagesModalBody.innerHTML = ''
                        + '<div class="pinned-empty-state">'
                        + '<i class="fa-solid fa-thumbtack"></i>'
                        + '<strong>Chưa ghim tin nhắn nào</strong>'
                        + '<p>Tin nhắn đã ghim trong đoạn chat này sẽ hiển thị ở đây</p>'
                        + '</div>';
                    return;
                }

                var lookup = {};
                allMessages.forEach(function (message) {
                    lookup[String(Number(message.id || 0))] = message;
                });

                var items = pinnedIds.map(function (id) {
                    return lookup[String(id)] || null;
                }).filter(function (message) {
                    return Boolean(message);
                }).sort(function (a, b) {
                    return parseDate(b.sentAt) - parseDate(a.sentAt);
                });

                if (items.length === 0) {
                    pinnedMessagesModalBody.innerHTML = ''
                        + '<div class="pinned-empty-state">'
                        + '<i class="fa-solid fa-thumbtack"></i>'
                        + '<strong>Chưa tải đủ tin nhắn đã ghim</strong>'
                        + '<p>Kéo lên lịch sử chat để tải thêm rồi mở lại.</p>'
                        + '</div>';
                    return;
                }

                var html = '<div class="pinned-message-list">';
                items.forEach(function (message) {
                    var messageId = Number(message.id || 0);
                    var senderName = Number(message.senderId || 0) === currentUserId
                        ? "Bạn"
                        : (message.senderName || "");
                    var contentText = (message.content || "").trim() || "(Tin nhắn đính kèm)";
                    var avatarUrl = escapeHtml(message.senderAvatarUrl || "https://via.placeholder.com/58");
                    var dateText = formatPinnedDate(message.sentAt);
                    var firstUrl = findFirstUrlInMessage(message, contentText);
                    var firstDomain = extractDomainFromUrl(firstUrl);

                    html += '<button type="button" class="pinned-message-item" data-action="open-pinned-message" data-message-id="' + messageId + '">';
                    html += '<div class="pinned-message-meta">';
                    html += '<div class="pinned-message-sender">' + escapeHtml(senderName) + "</div>";
                    html += '<div class="pinned-message-date">' + escapeHtml(dateText) + "</div>";
                    html += '</div>';
                    html += '<div class="pinned-message-row">';
                    html += '<img class="pinned-message-avatar" src="' + avatarUrl + '" alt="avatar" />';
                    html += '<div class="pinned-message-bubble-wrap"><div class="pinned-message-bubble">';
                    if (firstUrl) {
                        html += '<span class="pinned-message-link">' + escapeHtml(firstUrl) + "</span>";
                        if (firstDomain) {
                            html += '<div class="pinned-message-domain">' + escapeHtml(firstDomain) + "</div>";
                        }
                    } else {
                        html += '<div class="pinned-message-text">' + escapeHtml(contentText) + "</div>";
                    }
                    html += "</div></div>";
                    html += '</div>';
                    html += '<div class="pinned-message-hint">Enter</div>';
                    html += "</button>";
                });
                html += "</div>";
                pinnedMessagesModalBody.innerHTML = html;
            }

            function formatPinnedDate(value) {
                if (!value) return "";
                var date = new Date(value);
                if (Number.isNaN(date.getTime())) return "";
                return date.toLocaleDateString("vi-VN", {
                    day: "numeric",
                    month: "numeric",
                    year: "2-digit"
                });
            }

            function extractDomainFromUrl(value) {
                if (!value) return "";
                try {
                    return new URL(value).hostname || "";
                } catch {
                    return "";
                }
            }

            function findFirstUrlInMessage(message, fallbackText) {
                var attachments = Array.isArray(message && message.attachments) ? message.attachments : [];
                for (var i = 0; i < attachments.length; i++) {
                    var fileUrl = String((attachments[i] && attachments[i].fileUrl) || "").trim();
                    if (/^https?:\/\//i.test(fileUrl)) {
                        return fileUrl;
                    }
                }

                var text = String(fallbackText || "");
                var matched = text.match(/https?:\/\/[^\s]+/i);
                return matched ? matched[0] : "";
            }

            function syncRenameCount() {
                if (!renameConversationInput || !renameConversationCount) return;
                var value = renameConversationInput.value || "";
                renameConversationCount.textContent = String(value.length) + "/500";
