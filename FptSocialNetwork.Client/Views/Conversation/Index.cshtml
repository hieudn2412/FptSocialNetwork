            function syncRightProfileAvatarMode() {
                if (!rightProfileStack || !rightProfileSubAvatar) return;
                var shouldSingleAvatar = !Boolean(isGroupConversation) || Boolean(currentConversationHasCustomAvatar);
                rightProfileStack.classList.toggle("single", shouldSingleAvatar);
                rightProfileSubAvatar.style.display = shouldSingleAvatar ? "none" : "";
            }

            function normalizeMember(rawMember) {
                if (!rawMember) return null;

                var userId = Number(rawMember.userId || rawMember.UserId || 0);
                if (!userId) return null;
                return {
                    userId: userId,
                    fullName: String(rawMember.fullName || rawMember.FullName || "").trim(),
                    avatarUrl: String(rawMember.avatarUrl || rawMember.AvatarUrl || "").trim()
                };
            }

            function normalizeMemberList(rawMembers) {
                if (!Array.isArray(rawMembers)) return [];
                return rawMembers.map(function (member) {
                    return normalizeMember(member);
                }).filter(function (member) {
                    return Boolean(member);
                });
            }

            function renderConversationMembers() {
                if (!chatMembersList) return;
