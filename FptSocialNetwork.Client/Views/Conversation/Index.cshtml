            async function updateConversationSettings(payload) {
                if (!conversationId) return false;
                var requestBody = getRequestTokenParams();
                requestBody.append("conversationId", String(conversationId));
                if (payload && typeof payload.name === "string") {
                    requestBody.append("name", payload.name);
                }
                if (payload && typeof payload.avatarUrl === "string") {
                    requestBody.append("avatarUrl", payload.avatarUrl);
                }

                try {
                    var response = await fetch("/conversations/update-settings-json", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: requestBody.toString(),
                        credentials: "same-origin"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return false;
                    }

                    if (!response.ok) {
                        var errorMessage = await readResponseError(response, "Không thể cập nhật đoạn chat.");
                        window.alert(errorMessage);
                        return false;
                    }

                    var data = await response.json();
                    if (!data) return false;

                    setConversationDisplay(data.name || currentConversationName, data.avatarUrl || currentConversationAvatar);
                    scheduleConversationListRefresh(40);
                    return true;
                } catch {
                    return false;
                }
            }

            async function readResponseError(response, fallbackMessage) {
                if (!response) return fallbackMessage || "Có lỗi xảy ra.";
                try {
                    var contentType = String(response.headers.get("content-type") || "").toLowerCase();
                    if (contentType.indexOf("application/json") >= 0) {
                        var data = await response.json();
                        if (data && typeof data.error === "string" && data.error.trim()) {
                            return data.error.trim();
                        }
                    } else {
                        var text = await response.text();
                        if (text && text.trim()) {
                            return text.trim();
                        }
                    }
                } catch {
                    // Ignore parse error.
                }

                return fallbackMessage || "Có lỗi xảy ra.";
            }

