            function escapeHtml(value) {
                return String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");
            }

            function decodeHtmlEntities(value) {
                if (value === null || value === undefined) return "";
                var textarea = document.createElement("textarea");
                textarea.innerHTML = String(value);
                return textarea.value;
            }

            function escapeRegex(value) {
                return String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
            }

            function highlightSearchKeyword(content, keyword) {
                var text = String(content || "");
                var normalizedKeyword = String(keyword || "").trim();
                if (!normalizedKeyword) {
                    return escapeHtml(text);
                }

                var regex = new RegExp(escapeRegex(normalizedKeyword), "gi");
                var lastIndex = 0;
                var highlighted = "";
                var match = null;
                while ((match = regex.exec(text)) !== null) {
                    var start = match.index;
                    var end = regex.lastIndex;
                    highlighted += escapeHtml(text.slice(lastIndex, start));
                    highlighted += '<span class="message-search-hit">' + escapeHtml(text.slice(start, end)) + "</span>";
                    lastIndex = end;

                    if (regex.lastIndex === match.index) {
                        regex.lastIndex += 1;
                    }
                }

                highlighted += escapeHtml(text.slice(lastIndex));
                return highlighted;
            }

            function getRequestTokenParams() {
                var params = new URLSearchParams();
                if (antiForgeryToken) {
                    params.append("__RequestVerificationToken", antiForgeryToken);
                }
                return params;
            }

            function getPinnedStorageKey() {
                return "conversation-pins-" + String(conversationId || 0);
            }

            function loadPinnedMessagesFromStorage() {
                pinnedMessageIds = {};
                if (!conversationId || !window.localStorage) return;

                try {
                    var raw = window.localStorage.getItem(getPinnedStorageKey());
                    if (!raw) return;

                    var parsed = JSON.parse(raw);
                    if (!Array.isArray(parsed)) return;
                    parsed.forEach(function (id) {
                        var normalized = Number(id || 0);
                        if (!normalized) return;
                        pinnedMessageIds[String(normalized)] = true;
                    });
                } catch {
                    pinnedMessageIds = {};
                }
            }

            function persistPinnedMessages() {
                if (!conversationId || !window.localStorage) return;
                try {
                    var ids = Object.keys(pinnedMessageIds).map(function (id) { return Number(id); });
                    window.localStorage.setItem(getPinnedStorageKey(), JSON.stringify(ids));
                } catch {
                    // Ignore local storage errors.
                }
            }

            function isMessagePinned(messageId) {
                return Boolean(pinnedMessageIds[String(Number(messageId || 0))]);
            }

            function togglePinnedMessage(messageId) {
                var key = String(Number(messageId || 0));
                if (key === "0") return false;
                var pinned = false;

                if (pinnedMessageIds[key]) {
                    delete pinnedMessageIds[key];
                    persistPinnedMessages();
                    pinned = false;
                }
                else
                {
                    pinnedMessageIds[key] = true;
                    persistPinnedMessages();
                    pinned = true;
                }

                if (pinnedMessagesModal && pinnedMessagesModal.classList.contains("open")) {
                    renderPinnedMessagesModal();
                }

                return pinned;
            }

            function formatTime(value) {
                if (!value) return "";
                var date = new Date(value);
                if (Number.isNaN(date.getTime())) return "";
                return date.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
            }

            function getReactionSymbol(reactionType) {
                var normalized = String(reactionType || "").toLowerCase();
                if (normalized === "love") return "❤️";
                if (normalized === "haha") return "😂";
                if (normalized === "wow") return "😮";
                if (normalized === "sad") return "😢";
                if (normalized === "angry") return "😡";
                return "👍";
            }

            function parseDate(value) {
                var parsed = new Date(value || "");
                return Number.isNaN(parsed.getTime()) ? 0 : parsed.getTime();
            }

            function isImageAttachment(attachment) {
                if (!attachment) return false;
                var type = String(attachment.attachmentType || "").toLowerCase();
                return type === "image";
            }

            function computeLatestPageSnapshot(messages) {
                if (!Array.isArray(messages) || messages.length === 0) return "empty";

                return messages.map(function (message) {
                    var reactions = Array.isArray(message.reactions) ? message.reactions : [];
                    var seenBy = Array.isArray(message.seenBy) ? message.seenBy : [];
                    var attachments = Array.isArray(message.attachments) ? message.attachments : [];
                    var receipts = Array.isArray(message.receipts) ? message.receipts : [];
                    var reactionKey = reactions.map(function (reaction) {
                        return String(reaction.reactionType || "") + ":" + Number(reaction.count || 0) + ":" + (reaction.isMine ? "1" : "0");
                    }).join(",");
                    return [
                        Number(message.id || 0),
                        message.content || "",
                        message.editedAt || "",
                        message.isDeletedForEveryone ? "1" : "0",
                        seenBy.length,
                        attachments.length,
                        receipts.length,
                        reactionKey
                    ].join("#");
                }).join("|");
            }

            function upsertMessageInMemory(message) {
                if (!message) return false;

                var messageId = Number(message.id || 0);
                if (!messageId) return false;

                var index = allMessages.findIndex(function (item) {
                    return Number(item.id || 0) === messageId;
                });

                if (index >= 0) {
                    allMessages[index] = message;
                } else {
                    allMessages.push(message);
                }

                allMessages.sort(function (a, b) {
                    var sentDiff = parseDate(a.sentAt) - parseDate(b.sentAt);
                    if (sentDiff !== 0) return sentDiff;
                    return Number(a.id || 0) - Number(b.id || 0);
                });

                return true;
            }

            function applyRealtimeMessage(message, forceRender) {
                if (!panel || !message) return;
                if (Number(message.conversationId || 0) !== conversationId) return;

                var distanceToBottom = panel.scrollHeight - panel.scrollTop - panel.clientHeight;
                var shouldStickBottom = distanceToBottom < 120 || Number(message.senderId || 0) === currentUserId;
                var didUpdate = upsertMessageInMemory(message);
                if (!didUpdate) return;

                renderMessages(allMessages);
                if (shouldStickBottom) {
                    scrollToBottom();
                }

                scheduleConversationListRefresh(60);
                scheduleRealtimeSync(Boolean(forceRender));
            }

            function setReplyMessage(message) {
                if (message) {
                    setEditMessage(null, false);
                }

                selectedReplyMessage = message || null;
                if (!replyToInput) return;

                replyToInput.value = selectedReplyMessage ? String(selectedReplyMessage.id || "") : "";
                if (!replyPreview) return;

                if (!selectedReplyMessage) {
                    replyPreview.style.display = "none";
                    replyPreview.innerHTML = "";
                    return;
                }

                var senderName = Number(selectedReplyMessage.senderId || 0) === currentUserId
                    ? "Bạn"
                    : (selectedReplyMessage.senderName || "");
                var previewText = (selectedReplyMessage.content || "").trim();
                if (!previewText) {
                    previewText = selectedReplyMessage.isDeletedForEveryone
                        ? "Tin nhắn đã được gỡ"
                        : "(Tin nhắn đính kèm)";
                }

                replyPreview.innerHTML = ''
                    + '<div class="reply-preview-header">'
                    + '<strong>Đang trả lời</strong>'
                    + '<button type="button" class="close-preview-btn" id="clearReplyButton"><i class="fa-solid fa-xmark"></i></button>'
                    + '</div>'
                    + '<div class="reply-preview-content"><strong>' + escapeHtml(senderName) + ':</strong> ' + escapeHtml(previewText) + '</div>';
                replyPreview.style.display = "block";

                var clearReplyButton = document.getElementById("clearReplyButton");
                if (clearReplyButton) {
                    clearReplyButton.addEventListener("click", function () {
                        setReplyMessage(null);
                    });
                }
            }

            function setEditMessage(message, shouldFocus) {
                selectedEditMessage = message || null;
                if (!editPreview) return;

                if (!selectedEditMessage) {
                    editPreview.style.display = "none";
                    editPreview.innerHTML = "";
                    return;
                }

                setReplyMessage(null);
                editPreview.innerHTML = ''
                    + '<div class="reply-preview-header">'
                    + '<strong>Đang chỉnh sửa</strong>'
                    + '<button type="button" class="close-preview-btn" id="clearEditButton"><i class="fa-solid fa-xmark"></i></button>'
                    + '</div>'
                    + '<div class="reply-preview-content">' + escapeHtml(selectedEditMessage.content || "") + "</div>";
                editPreview.style.display = "block";

                if (messageInput) {
                    messageInput.value = selectedEditMessage.content || "";
                    if (shouldFocus) {
                        messageInput.focus();
                    }
                }

                var clearEditButton = document.getElementById("clearEditButton");
                if (clearEditButton) {
                    clearEditButton.addEventListener("click", function () {
                        setEditMessage(null, false);
                    });
                }
            }

            function renderAttachmentPreview() {
                if (!attachmentPreview || !attachmentInput) return;
                var files = Array.prototype.slice.call(attachmentInput.files || []);
                if (files.length === 0) {
                    attachmentPreview.style.display = "none";
                    attachmentPreview.innerHTML = "";
                    return;
                }

                var itemsHtml = files.map(function (file) {
                    return '<div class="attachment-preview-item">' + escapeHtml(file.name || "file") + "</div>";
                }).join("");

                attachmentPreview.innerHTML = ''
                    + '<div class="attachment-preview-header">'
                    + '<strong>Tệp đính kèm (' + files.length + ')</strong>'
                    + '<button type="button" class="close-preview-btn" id="clearAttachmentButton"><i class="fa-solid fa-xmark"></i></button>'
                    + '</div>'
                    + '<div class="attachment-preview-list">' + itemsHtml + "</div>";
                attachmentPreview.style.display = "block";

                var clearAttachmentButton = document.getElementById("clearAttachmentButton");
                if (clearAttachmentButton) {
                    clearAttachmentButton.addEventListener("click", function () {
                        attachmentInput.value = "";
                        renderAttachmentPreview();
                    });
                }
            }

            function renderTypingIndicator() {
                if (!typingIndicator) return;

                var names = Object.keys(typingUsers).map(function (key) {
                    return typingUsers[key];
                }).filter(function (value) {
                    return Boolean(value);
                });

                if (names.length === 0) {
                    typingIndicator.textContent = "";
                    return;
                }

                if (names.length === 1) {
                    typingIndicator.textContent = names[0] + " đang nhập...";
                    return;
                }

                typingIndicator.textContent = names.slice(0, 2).join(", ") + " đang nhập...";
            }

            async function sendTypingState(isTyping) {
                if (!connection || connection.state !== signalR.HubConnectionState.Connected || !conversationId) {
                    return;
                }

                try {
                    if (isTyping) {
                        if (hasSentTyping) return;
                        await connection.invoke("StartTyping", conversationId);
                        hasSentTyping = true;
                        return;
                    }

                    if (!hasSentTyping) return;
                    await connection.invoke("StopTyping", conversationId);
                    hasSentTyping = false;
                } catch {
                    // Ignore typing transport errors.
                }
            }

            function getReceiptInfo(message, isMine) {
                if (!isMine) {
                    return { text: "", title: "" };
                }

                var receipts = Array.isArray(message.receipts) ? message.receipts : [];
                if (receipts.length === 0) {
                    return { text: "Đã gửi", title: "Đã gửi" };
                }

                var seen = receipts.filter(function (item) {
                    return String(item.status || "").toLowerCase() === "seen";
                });
                var delivered = receipts.filter(function (item) {
                    return String(item.status || "").toLowerCase() === "delivered";
                });

                if (seen.length > 0) {
                    var seenNames = seen.map(function (item) {
                        return item.fullName || "Người dùng";
                    });
                    var seenPreview = seenNames.slice(0, 2).join(", ");
                    if (seenNames.length > 2) {
                        seenPreview += " +" + (seenNames.length - 2);
                    }

                    return {
                        text: "Đã xem: " + seenPreview,
                        title: "Đã xem: " + seenNames.join(", ")
                    };
                }

                return {
                    text: "Đã nhận: " + delivered.length + "/" + receipts.length,
                    title: "Đã nhận: " + delivered.map(function (item) { return item.fullName || "Người dùng"; }).join(", ")
                };
            }

            function buildConversationHref(targetConversationId) {
                var params = new URLSearchParams();
                params.set("conversationId", String(targetConversationId));
                if (currentTab) {
                    params.set("tab", currentTab);
                }

                return "/conversations?" + params.toString();
            }

            function buildConversationListRootHref() {
                var params = new URLSearchParams();
                if (currentTab) {
                    params.set("tab", currentTab);
                }

                var query = params.toString();
                return query ? ("/conversations?" + query) : "/conversations";
            }

            function buildConversationListItemHtml(conversation) {
                var id = Number(conversation.id || 0);
                var isActive = id === conversationId;
                var hasUnread = Boolean(conversation.hasUnread) && !isActive;
                var lastSenderId = conversation.lastSenderId === null || conversation.lastSenderId === undefined
                    ? null
                    : Number(conversation.lastSenderId);

                var prefix = "";
                if (lastSenderId !== null) {
                    prefix = lastSenderId === currentUserId
                        ? "Bạn: "
                        : ((conversation.lastSenderName || "") + ": ");
                }

                var lastMessage = (conversation.lastMessage || "").trim();
                var preview = lastMessage ? (prefix + lastMessage) : "(Chưa có tin nhắn)";
                var avatar = conversation.avatarUrl || "https://via.placeholder.com/56";
                var unreadBadge = hasUnread
                    ? '<div class="unread-badge">' + Number(conversation.unreadCount || 0) + "</div>"
                    : "";

                var html = '<div class="conversation-list-item ' + (isActive ? "active" : "") + '" data-conversation-id="' + id + '">';
                html += '<a class="conversation-item-link" href="' + escapeHtml(buildConversationHref(id)) + '">';
                html += '<div class="avatar-wrap">';
                html += '<img class="avatar" src="' + escapeHtml(avatar) + '" alt="avatar" />';
                html += "</div>";
                html += '<div class="conversation-content">';
                html += '<div class="conversation-name">' + escapeHtml(conversation.name || "") + "</div>";
                html += '<div class="conversation-preview ' + (hasUnread ? "unread" : "") + '">';
                html += escapeHtml(preview);
                html += "</div></div>";
                html += "</a>";
                html += '<div class="conversation-trailing">';
                html += unreadBadge;
                html += '<div class="conversation-actions">';
                html += '<button type="button" class="conversation-more-btn" data-action="toggle-conversation-menu" data-conversation-id="' + id + '" aria-label="Tùy chọn đoạn chat">';
                html += '<i class="fa-solid fa-ellipsis"></i>';
                html += "</button>";
                html += '<div class="conversation-more-menu" data-conversation-menu="' + id + '">';
                html += '<button type="button" class="conversation-menu-item danger" data-action="delete-conversation" data-conversation-id="' + id + '">Xóa đoạn chat</button>';
                html += "</div>";
                html += "</div>";
                html += "</div>";
                html += "</div>";
                return html;
            }

            function closeConversationMenus() {
                if (!conversationList) return;

                var openedMenus = conversationList.querySelectorAll(".conversation-more-menu.open");
                openedMenus.forEach(function (menu) {
                    menu.classList.remove("open");
                });

                var openedItems = conversationList.querySelectorAll(".conversation-list-item.menu-open");
                openedItems.forEach(function (item) {
                    item.classList.remove("menu-open");
                });
            }

            function toggleConversationMenu(button) {
                if (!button) return;
                var container = button.closest(".conversation-list-item");
                if (!container) return;
                var menu = container.querySelector(".conversation-more-menu");
                if (!menu) return;

                var shouldOpen = !menu.classList.contains("open");
                closeConversationMenus();
                if (!shouldOpen) {
                    return;
                }

                menu.classList.add("open");
                container.classList.add("menu-open");
            }

            function closeDeleteConversationConfirm() {
                pendingDeleteConversationId = 0;
                if (confirmDeleteConversationButton) {
                    confirmDeleteConversationButton.disabled = false;
                }
                setModalOpen(deleteConversationConfirmModal, false);
            }

            function openDeleteConversationConfirm(targetConversationId) {
                var id = Number(targetConversationId || 0);
                if (!id || isDeletingConversation) return;
                closeConversationMenus();
                pendingDeleteConversationId = id;
                if (confirmDeleteConversationButton) {
                    confirmDeleteConversationButton.disabled = false;
                }
                setModalOpen(deleteConversationConfirmModal, true);
            }

            async function deleteConversationForEveryone(targetConversationId) {
                var id = Number(targetConversationId || 0);
                if (!id || isDeletingConversation) return;

                isDeletingConversation = true;
                if (confirmDeleteConversationButton) {
                    confirmDeleteConversationButton.disabled = true;
                }
                try {
                    var response = await postWithToken("/conversations/delete-conversation-json", {
                        conversationId: String(id)
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) {
                        var errorText = "Không thể xóa đoạn chat.";
                        try {
                            var payload = await response.json();
                            if (payload && payload.error) {
                                errorText = String(payload.error);
                            }
                        } catch {
                            // Keep default error message.
                        }

                        window.alert(errorText);
                        return;
                    }

                    closeConversationMenus();
                    closeDeleteConversationConfirm();

                    if (id === conversationId) {
                        window.location.href = buildConversationListRootHref();
                        return;
                    }

                    await refreshConversationList();
                } catch {
                    window.alert("Không thể xóa đoạn chat.");
                } finally {
                    isDeletingConversation = false;
                    if (confirmDeleteConversationButton) {
                        confirmDeleteConversationButton.disabled = false;
                    }
                }
            }

            function setActiveConversationInList(targetConversationId) {
                if (!conversationList) return;

                var targetId = Number(targetConversationId || 0);
                var items = conversationList.querySelectorAll(".conversation-list-item");
                items.forEach(function (item) {
                    var itemId = Number(item.getAttribute("data-conversation-id") || 0);
                    item.classList.toggle("active", itemId === targetId);
                });
            }

            async function fetchConversationDetail(targetConversationId) {
                var response = await fetch("/conversations/detail-json?conversationId=" + encodeURIComponent(String(targetConversationId)), {
                    method: "GET",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    cache: "no-store"
                });

                if (response.status === 401) {
                    window.location.href = "/Account/Login";
                    return null;
                }

                if (!response.ok) {
                    throw new Error(await readResponseError(response, "Không thể tải đoạn chat."));
                }

                return await response.json();
            }

            async function switchConversation(targetConversationId, shouldPushHistory) {
                var nextConversationId = Number(targetConversationId || 0);
                if (!nextConversationId || nextConversationId === conversationId || isSwitchingConversation) {
                    return;
                }

                var previousConversationId = conversationId;
                isSwitchingConversation = true;

                try {
                    if (connection && connection.state === signalR.HubConnectionState.Connected && previousConversationId) {
                        try {
                            await connection.invoke("LeaveConversation", previousConversationId);
                        } catch {
                            // Ignore leave errors while switching.
                        }
                    }

                    conversationId = nextConversationId;
                    if (panel) {
                        panel.dataset.conversationId = String(nextConversationId);
                    }
                    if (conversationIdInput) {
                        conversationIdInput.value = String(nextConversationId);
                    }
                    if (sendButton) {
                        sendButton.disabled = false;
                    }

                    setActiveConversationInList(nextConversationId);
                    closeAllMessageMenus();
                    closeConversationMenus();
                    setReplyMessage(null);
                    setEditMessage(null, false);
                    typingUsers = {};
                    renderTypingIndicator();

                    loadedPage = 1;
                    hasMorePages = true;
                    isLoadingOlder = false;
                    latestPageSnapshot = "";
                    allMessages = [];
                    renderMessages(allMessages);

                    var detail = await fetchConversationDetail(nextConversationId);
                    if (!detail) {
                        return;
                    }

                    applyConversationDetail(detail);
                    loadPinnedMessagesFromStorage();

                    if (connection && connection.state === signalR.HubConnectionState.Connected) {
                        try {
                            await connection.invoke("JoinConversation", nextConversationId);
                        } catch {
                            // Ignore join errors; polling/reload path will recover.
                        }
                    }

                    await loadLatestMessages(true, true);
                    scheduleConversationListRefresh(30);

                    if (rightSearchPanel && rightSearchPanel.style.display !== "none") {
                        searchConversationMessages(messageSearchInput ? messageSearchInput.value : "");
                    }

                    if (shouldPushHistory) {
                        history.pushState({ conversationId: nextConversationId }, "", buildConversationHref(nextConversationId));
                    }
                } catch (error) {
                    if (error && error.message) {
                        window.alert(error.message);
                    }

                    conversationId = previousConversationId;
                    if (panel) {
                        panel.dataset.conversationId = String(previousConversationId || 0);
                    }
                    if (conversationIdInput) {
                        conversationIdInput.value = String(previousConversationId || 0);
                    }
                    setActiveConversationInList(previousConversationId);

                    if (previousConversationId && connection && connection.state === signalR.HubConnectionState.Connected) {
                        try {
                            await connection.invoke("JoinConversation", previousConversationId);
                        } catch {
                            // Ignore rejoin failure.
                        }
                    }

                    if (previousConversationId) {
                        window.location.href = buildConversationHref(previousConversationId);
                    } else {
                        window.location.href = buildConversationListRootHref();
                    }
                } finally {
                    isSwitchingConversation = false;
                }
            }

            function renderConversationList(conversations) {
                if (!conversationList) return;

                if (!Array.isArray(conversations) || conversations.length === 0) {
                    conversationList.innerHTML = '<div class="conversation-preview" style="padding: 8px 10px;">Không có đoạn chat.</div>';
                    return;
                }

                var html = "";
                conversations.forEach(function (conversation) {
                    html += buildConversationListItemHtml(conversation);
                });

                conversationList.innerHTML = html;
            }

            async function refreshConversationList() {
                if (!conversationList) return;

                var endpoint = "/conversations/list-json";
                var queryParts = [];
                if (currentTab) {
                    queryParts.push("tab=" + encodeURIComponent(currentTab));
                }
                if (queryParts.length > 0) {
                    endpoint += "?" + queryParts.join("&");
                }

                try {
                    var response = await fetch(endpoint, {
                        method: "GET",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        cache: "no-store"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return false;
                    var conversations = await response.json();
                    renderConversationList(conversations);
                } catch {
                    // Ignore transient refresh errors.
                }
            }

            function renderUserSearch(users) {
                if (!userSearchResultsPanel || !userSearchResultsContent) return;

                if (!Array.isArray(users) || users.length === 0) {
                    userSearchResultsContent.innerHTML = '<div class="conversation-preview">Không tìm thấy người dùng phù hợp.</div>';
                    userSearchResultsPanel.style.display = "block";
                    return;
                }

                var html = "";
                users.forEach(function (user) {
                    var userId = Number(user.userId || 0);
                    var fullName = escapeHtml(user.fullName || "");
                    var email = escapeHtml(user.email || "");
                    var avatar = escapeHtml(user.avatarUrl || "https://via.placeholder.com/56");

                    html += '<a class="conversation-item"';
                    html += ' href="/conversations/start-user/' + userId + '"';
                    html += ' style="text-decoration:none;color:inherit;">';
                    html += '<div class="avatar-wrap"><img class="avatar" src="' + avatar + '" alt="avatar" /></div>';
                    html += '<div class="conversation-content">';
                    html += '<div class="conversation-name">' + fullName + "</div>";
                    html += '<div class="conversation-preview">' + email + "</div>";
                    html += "</div></a>";
                });

                userSearchResultsContent.innerHTML = html;
                userSearchResultsPanel.style.display = "block";
            }

            async function searchUsersRealtime(keyword) {
                if (!userSearchResultsPanel || !userSearchResultsContent) return;

                var trimmed = (keyword || "").trim();
                if (!trimmed) {
                    userSearchResultsContent.innerHTML = "";
                    userSearchResultsPanel.style.display = "none";
                    return;
                }

                var requestId = ++searchRequestSequence;
                try {
                    var response = await fetch("/conversations/users-search-json?q=" + encodeURIComponent(trimmed), {
                        method: "GET",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        cache: "no-store"
                    });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    var users = await response.json();
                    if (requestId !== searchRequestSequence) return;
                    renderUserSearch(users);
                } catch {
                    // Ignore transient errors while typing.
                }
            }

            function toggleMessageSearchPanel(isOpen) {
                if (!rightInfoPanel || !rightSearchPanel) return;

                rightInfoPanel.style.display = isOpen ? "none" : "block";
                rightSearchPanel.style.display = isOpen ? "flex" : "none";
                if (!isOpen) {
                    if (messageSearchInput) {
                        messageSearchInput.disabled = false;
                    }
                    return;
                }

                if (messageSearchInput) {
                    messageSearchInput.disabled = !conversationId;
                    messageSearchInput.placeholder = conversationId
                        ? "Tìm kiếm trong cuộc trò chuyện"
                        : "Chọn đoạn chat để tìm kiếm";
                }

                if (!conversationId) {
                    if (messageSearchResults) {
                        messageSearchResults.innerHTML = '<div class="message-search-empty">Hãy chọn một đoạn chat trước khi tìm kiếm.</div>';
                    }
                    setMessageSearchCount(null, false);
                    return;
                }

                if (messageSearchInput) {
                    messageSearchInput.focus();
                }
            }

            function setMessageSearchCount(totalCount, hasKeyword) {
                if (!messageSearchCount) return;

                if (!hasKeyword) {
                    messageSearchCount.textContent = "";
                    messageSearchCount.style.display = "none";
                    return;
                }

                var count = Number(totalCount || 0);
                var text = count > 99 ? "Hơn 99 kết quả" : (String(count) + " kết quả");
                messageSearchCount.textContent = text;
                messageSearchCount.style.display = "inline";
            }

            function formatSearchTime(value) {
                if (!value) return "";
                var date = new Date(value);
                if (Number.isNaN(date.getTime())) return "";
                return date.toLocaleString([], {
                    day: "2-digit",
                    month: "2-digit",
                    hour: "2-digit",
                    minute: "2-digit"
                });
            }

            function renderMessageSearchResults(items, keyword) {
                if (!messageSearchResults) return;

                if (!Array.isArray(items) || items.length === 0) {
                    messageSearchResults.innerHTML = '<div class="message-search-empty">Không tìm thấy tin nhắn phù hợp.</div>';
                    return;
                }

                var html = "";
                items.forEach(function (item) {
                    var messageId = Number(item.messageId || 0);
                    if (!messageId) return;
                    var avatar = escapeHtml(item.senderAvatarUrl || "https://via.placeholder.com/46");
                    var timeText = formatSearchTime(item.sentAt);
                    var contentText = (item.content || "").trim();
                    if (!contentText) {
                        contentText = "(Tin nhắn đính kèm)";
                    }

                    html += '<button type="button" class="message-search-item" data-message-id="' + messageId + '">';
                    html += '<img class="message-search-avatar" src="' + avatar + '" alt="avatar" />';
                    html += '<div class="message-search-meta">';
                    html += '<div class="message-search-sender">' + escapeHtml(item.senderName || "") + "</div>";
                    html += '<div class="message-search-content-row">';
                    html += '<div class="message-search-content">' + highlightSearchKeyword(contentText, keyword) + "</div>";
                    if (timeText) {
                        html += '<div class="message-search-time">· ' + escapeHtml(timeText) + "</div>";
                    }
                    html += "</div>";
                    html += "</div>";
                    html += "</button>";
                });

                messageSearchResults.innerHTML = html || '<div class="message-search-empty">Không tìm thấy tin nhắn phù hợp.</div>';
            }

            function highlightMessageRow(messageId) {
                if (!panel) return null;

                var highlighted = panel.querySelectorAll(".message-row.search-hit");
                highlighted.forEach(function (element) {
                    element.classList.remove("search-hit");
                });

                var target = panel.querySelector('.message-row[data-message-id="' + String(messageId) + '"]');
                if (!target) return null;

                target.classList.add("search-hit");
                setTimeout(function () {
                    target.classList.remove("search-hit");
                }, 2500);

                return target;
            }

            async function jumpToMessage(messageId) {
                var id = Number(messageId || 0);
                if (!id || !panel) return;

                var target = highlightMessageRow(id);
                var attempts = 0;
                while (!target && hasMorePages && attempts < 30) {
                    var loaded = await loadOlderMessages();
                    if (!loaded) break;
                    attempts += 1;
                    target = highlightMessageRow(id);
                }

                if (!target) return;
                target.scrollIntoView({ behavior: "smooth", block: "center" });
            }

            function closeAllMessageMenus() {
                if (!panel) return;
                var openedMenus = panel.querySelectorAll(".message-more-menu.open");
                openedMenus.forEach(function (menu) {
                    menu.classList.remove("open");
                });
            }

            function toggleMessageMenu(toggleButton) {
                var wrapper = toggleButton ? toggleButton.closest(".message-more-wrap") : null;
                var menu = wrapper ? wrapper.querySelector(".message-more-menu") : null;
                if (!menu) return;

                var shouldOpen = !menu.classList.contains("open");
                closeAllMessageMenus();
                if (shouldOpen) {
                    menu.classList.add("open");
                }
            }

            async function searchConversationMessages(keyword) {
                if (!messageSearchResults) return;
                if (!conversationId) {
                    messageSearchResults.innerHTML = '<div class="message-search-empty">Hãy chọn một đoạn chat trước khi tìm kiếm.</div>';
                    setMessageSearchCount(null, false);
                    return;
                }

                var requestConversationId = conversationId;

                var trimmed = (keyword || "").trim();
                if (!trimmed) {
                    messageSearchResults.innerHTML = '<div class="message-search-empty">Nhập nội dung để tìm lịch sử tin nhắn.</div>';
                    setMessageSearchCount(null, false);
                    return;
                }

                var requestId = ++messageSearchRequestSequence;
                messageSearchResults.innerHTML = '<div class="message-search-empty">Đang tìm kiếm...</div>';
                try {
                    var response = await fetch(
                        "/conversations/search-messages-json?conversationId=" + requestConversationId + "&q=" + encodeURIComponent(trimmed) + "&page=1&pageSize=40",
                        {
                            method: "GET",
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            cache: "no-store"
                        });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    var payload = await response.json();
                    if (requestId !== messageSearchRequestSequence || requestConversationId !== conversationId) return;
                    var items = Array.isArray(payload)
                        ? payload
                        : (Array.isArray(payload.items) ? payload.items : []);
                    var totalCount = Array.isArray(payload)
                        ? items.length
                        : Number(payload.totalCount || 0);
                    setMessageSearchCount(totalCount, true);
                    renderMessageSearchResults(items, trimmed);
                } catch {
                    // Ignore transient search errors.
                }
            }

            function renderMessages(messages) {
                if (!panel) return;
                allMessages = Array.isArray(messages) ? messages : [];

                if (!Array.isArray(allMessages) || allMessages.length === 0) {
                    panel.innerHTML = '<div class="time-divider">Chưa có tin nhắn</div>';
                    panel.dataset.lastMessageId = "0";
                    return;
                }

                var html = "";
                allMessages.forEach(function (message) {
                    var isMine = message.senderId === currentUserId;
                    var sender = escapeHtml(isMine ? "Bạn" : message.senderName);
                    var timeText = formatTime(message.sentAt);
                    var timeLabel = timeText + (message.editedAt ? " (đã sửa)" : "");
                    var avatar = escapeHtml(message.senderAvatarUrl || "https://via.placeholder.com/32");
                    var content = escapeHtml(message.content || "");
                    var replyTo = message.replyTo || null;
                    var attachments = Array.isArray(message.attachments) ? message.attachments : [];
                    var reactions = Array.isArray(message.reactions) ? message.reactions : [];
                    var seenBy = Array.isArray(message.seenBy) ? message.seenBy : [];
                    var isDeleted = Boolean(message.isDeletedForEveryone);
                    var messageId = Number(message.id || 0);
                    var isPinned = isMessagePinned(messageId);
                    var replyHtml = "";
                    if (replyTo) {
                        var replySender = Number(replyTo.senderId || 0) === currentUserId ? "Bạn" : escapeHtml(replyTo.senderName || "");
                        var replyContent = escapeHtml(replyTo.isDeletedForEveryone ? "Tin nhắn đã được gỡ" : (replyTo.content || ""));
                        replyHtml = '<div class="reply-snippet"><strong>' + replySender + '</strong><span>' + replyContent + "</span></div>";
                    }

                    var attachmentsHtml = isDeleted ? "" : attachments.map(function (attachment) {
                        var fileName = escapeHtml(attachment.fileName);
                        var fileUrl = escapeHtml(attachment.fileUrl);
                        if (isImageAttachment(attachment)) {
                            return '<div class="bubble"><a href="' + fileUrl + '" target="_blank" rel="noopener noreferrer"><img src="' + fileUrl + '" alt="' + fileName + '" class="attachment-image" /></a></div>';
                        }

                        return '<div class="bubble"><a href="' + fileUrl + '" target="_blank" rel="noopener noreferrer">' + fileName + "</a></div>";
                    }).join("");

                    var reactionHtml = reactions.map(function (reaction) {
                        var className = "reaction-chip" + (reaction.isMine ? " mine" : "");
                        return '<span class="' + className + '">' + getReactionSymbol(reaction.reactionType) + " " + Number(reaction.count || 0) + "</span>";
                    }).join("");

                    var actionsHtml = '<div class="message-inline-actions">';
                    if (!isDeleted) {
                        actionsHtml += '<button type="button" class="message-action-icon" data-action="react-like" data-message-id="' + messageId + '" title="Bày tỏ cảm xúc"><i class="fa-regular fa-face-smile"></i></button>';
                    }
                    actionsHtml += '<button type="button" class="message-action-icon" data-action="reply" data-message-id="' + messageId + '" title="Trả lời"><i class="fa-solid fa-reply"></i></button>';
                    actionsHtml += '<div class="message-more-wrap">';
                    actionsHtml += '<button type="button" class="message-action-icon" data-action="toggle-menu" data-message-id="' + messageId + '" title="Khác"><i class="fa-solid fa-ellipsis"></i></button>';
                    actionsHtml += '<div class="message-more-menu" data-message-id="' + messageId + '">';
                    actionsHtml += '<button type="button" data-action="menu-remove" data-message-id="' + messageId + '">Gỡ</button>';
                    actionsHtml += '<button type="button" data-action="toggle-pin" data-message-id="' + messageId + '">' + (isPinned ? "Bỏ ghim" : "Ghim") + "</button>";
                    actionsHtml += "</div></div></div>";

                    var seenHtml = "";
                    if (isMine && seenBy.length > 0) {
                        var seenAvatars = seenBy.slice(0, 4).map(function (member) {
                            var seenAvatar = escapeHtml(member.avatarUrl || "https://via.placeholder.com/18");
                            return '<img src="' + seenAvatar + '" alt="seen" />';
                        }).join("");
                        seenHtml = '<div class="seen-icons">' + seenAvatars + "</div>";
                    }

                    html += '<div class="message-row ' + (isMine ? "own" : "") + '" data-message-id="' + messageId + '">';
                    if (!isMine) {
                        html += '<img class="message-avatar" src="' + avatar + '" alt="avatar" />';
                    }
                    html += '<div class="message-body">';
                    html += '<div class="message-group">';
                    if (!isMine && isGroupConversation) {
                        html += '<div class="sender-name">' + sender + "</div>";
                    }
                    html += replyHtml;
                    html += '<div class="bubble">' + content + "</div>";
                    html += attachmentsHtml;
                    if (isPinned) {
                        html += '<div class="message-pin"><i class="fa-solid fa-thumbtack"></i><span>Đã ghim</span></div>';
                    }
                    if (reactionHtml) {
                        html += '<div class="reaction-row">' + reactionHtml + "</div>";
                    }
                    html += seenHtml;
                    html += "</div>";
                    html += '<div class="message-hover-time">' + escapeHtml(timeLabel) + "</div>";
                    html += actionsHtml;
                    html += "</div></div>";
                });

                panel.innerHTML = html;
                panel.dataset.lastMessageId = String(allMessages[allMessages.length - 1].id || 0);
            }

            function mergeLatestPage(latestPage) {
                var normalizedLatest = Array.isArray(latestPage) ? latestPage : [];
                var latestIds = {};
                normalizedLatest.forEach(function (item) {
                    latestIds[String(Number(item.id || 0))] = true;
                });

                var retainedOlder = allMessages.filter(function (item) {
                    return !latestIds[String(Number(item.id || 0))];
                });

                allMessages = retainedOlder.concat(normalizedLatest);
                allMessages.sort(function (a, b) {
                    var sentDiff = parseDate(a.sentAt) - parseDate(b.sentAt);
                    if (sentDiff !== 0) return sentDiff;
                    return Number(a.id || 0) - Number(b.id || 0);
                });
            }

            async function loadLatestMessages(forceScroll, forceRender) {
                if (!panel || !conversationId) return;
                var requestConversationId = conversationId;
                try {
                    var response = await fetch(
                        "/conversations/messages-json?conversationId=" + requestConversationId + "&page=1&pageSize=" + pageSize + "&markRead=true",
                        {
                            method: "GET",
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            cache: "no-store"
                        });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    var latestMessages = await response.json();
                    if (requestConversationId !== conversationId) return;
                    var newSnapshot = computeLatestPageSnapshot(latestMessages);
                    if (!forceRender && !forceScroll && latestPageSnapshot === newSnapshot) {
                        return;
                    }

                    latestPageSnapshot = newSnapshot;
                    hasMorePages = Array.isArray(latestMessages) && latestMessages.length === pageSize;
                    loadedPage = 1;

                    var distanceToBottom = panel.scrollHeight - panel.scrollTop - panel.clientHeight;
                    var shouldStickBottom = forceScroll || distanceToBottom < 120;
                    mergeLatestPage(latestMessages);
                    renderMessages(allMessages);
                    if (shouldStickBottom) {
                        scrollToBottom();
                    }

                    await refreshConversationList();
                } catch {
                    // Keep UI responsive even if background refresh fails.
                }
            }

            async function loadOlderMessages() {
                if (!panel || !conversationId || !hasMorePages || isLoadingOlder) return false;
                var requestConversationId = conversationId;

                isLoadingOlder = true;
                var nextPage = loadedPage + 1;
                var beforeHeight = panel.scrollHeight;
                var beforeTop = panel.scrollTop;
                var didLoadAny = false;

                try {
                    var response = await fetch(
                        "/conversations/messages-json?conversationId=" + requestConversationId + "&page=" + nextPage + "&pageSize=" + pageSize + "&markRead=false",
                        {
                            method: "GET",
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            cache: "no-store"
                        });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    var olderMessages = await response.json();
                    if (requestConversationId !== conversationId) return false;
                    if (!Array.isArray(olderMessages) || olderMessages.length === 0) {
                        hasMorePages = false;
                        return false;
                    }

                    var existing = {};
                    allMessages.forEach(function (item) {
                        existing[String(Number(item.id || 0))] = true;
                    });

                    var toPrepend = olderMessages.filter(function (item) {
                        return !existing[String(Number(item.id || 0))];
                    });

                    if (toPrepend.length > 0) {
                        allMessages = toPrepend.concat(allMessages);
                        renderMessages(allMessages);
                        panel.scrollTop = panel.scrollHeight - beforeHeight + beforeTop;
                        didLoadAny = true;
                    }

                    loadedPage = nextPage;
                    if (olderMessages.length < pageSize) {
                        hasMorePages = false;
                    }
                } catch {
                    // Ignore transient load older errors.
                } finally {
                    isLoadingOlder = false;
                }

                return didLoadAny;
            }

            async function initRealtime() {
                if (!conversationId || !window.signalR || !realtimeToken || !chatHubUrl) {
                    startPolling();
                    return;
                }

                connection = new signalR.HubConnectionBuilder()
                    .withUrl(chatHubUrl, {
                        accessTokenFactory: function () { return realtimeToken; }
                    })
                    .withAutomaticReconnect([0, 2000, 5000, 10000])
                    .build();

                connection.on("MessageReceived", function (message) {
                    applyRealtimeMessage(message, false);
                });

                connection.on("MessageUpdated", function (message) {
                    applyRealtimeMessage(message, true);
                });

                connection.on("SeenUpdated", function (payload) {
                    if (!payload) return;
                    if (Number(payload.conversationId || 0) !== conversationId) return;
                    if (Number(payload.userId || 0) === currentUserId) return;
                    scheduleRealtimeSync(true);
                });

                connection.on("TypingUpdated", function (payload) {
                    if (!payload) return;
                    if (Number(payload.conversationId || 0) !== conversationId) return;

                    var typingUserId = Number(payload.userId || 0);
                    if (!typingUserId || typingUserId === currentUserId) return;

                    if (payload.isTyping) {
                        typingUsers[String(typingUserId)] = payload.userName || "Ai đó";
                    } else {
                        delete typingUsers[String(typingUserId)];
                    }
                    renderTypingIndicator();
                });

                connection.on("ConversationUpdated", function (payload) {
                    if (!payload) return;
                    scheduleConversationListRefresh(40);
                });

                connection.on("ConversationDeleted", function (payload) {
                    if (!payload) return;

                    var deletedConversationId = Number(payload.conversationId || 0);
                    if (!deletedConversationId) return;
                    if (pendingDeleteConversationId === deletedConversationId) {
                        closeDeleteConversationConfirm();
                    }

                    closeConversationMenus();
                    scheduleConversationListRefresh(20);

                    if (deletedConversationId === conversationId) {
                        window.location.href = buildConversationListRootHref();
                    }
                });

                connection.onreconnecting(function () {
                    startPolling();
                });

                connection.onreconnected(async function () {
                    try {
                        await connection.invoke("JoinConversation", conversationId);
                        stopPolling();
                        await loadLatestMessages(false, true);
                        scheduleConversationListRefresh(20);
                    } catch {
                        startPolling();
                    }
                });

                connection.onclose(function () {
                    startPolling();
                });

                try {
                    await connection.start();
                    await connection.invoke("JoinConversation", conversationId);
                    stopPolling();
                    scheduleConversationListRefresh(20);
                } catch {
                    startPolling();
                }
            }

            async function postWithToken(endpoint, additionalFields) {
                var body = getRequestTokenParams();
                var fields = additionalFields || {};
                Object.keys(fields).forEach(function (key) {
                    body.append(key, fields[key]);
                });

                return await fetch(endpoint, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: body.toString(),
                    credentials: "same-origin"
                });
            }

            async function toggleReaction(messageId, reactionType) {
                try {
                    var response = await postWithToken(
                        "/conversations/message/" + encodeURIComponent(String(messageId)) + "/reaction",
                        { reactionType: reactionType });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    await loadLatestMessages(false, true);
                } catch {
                    // Ignore transient reaction errors.
                }
            }

            async function unsendMessage(messageId) {
                try {
                    var response = await postWithToken(
                        "/conversations/message/" + encodeURIComponent(String(messageId)) + "/unsend");

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    await loadLatestMessages(false, true);
                    await refreshConversationList();
                } catch {
                    // Ignore transient unsend errors.
                }
            }

            async function editMessage(messageId, content) {
                try {
                    var response = await postWithToken(
                        "/conversations/message/" + encodeURIComponent(String(messageId)) + "/edit",
                        { content: content });

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return false;
                    }

                    if (!response.ok) return false;
                    await loadLatestMessages(false, true);
                    return true;
                } catch {
                    return false;
                }
            }

            async function hideMessageForMe(messageId) {
                try {
                    var response = await postWithToken("/conversations/message/" + encodeURIComponent(String(messageId)) + "/hide");

                    if (response.status === 401) {
                        window.location.href = "/Account/Login";
                        return;
                    }

                    if (!response.ok) return;
                    allMessages = allMessages.filter(function (item) {
                        return Number(item.id || 0) !== Number(messageId);
                    });
                    renderMessages(allMessages);
                    await refreshConversationList();
                } catch {
                    // Ignore transient hide errors.
                }
            }

            if (panel) {
                panel.addEventListener("click", function (event) {
                    var trigger = event.target.closest("[data-action]");
                    if (!trigger) {
                        closeAllMessageMenus();
                        return;
                    }

                    var action = trigger.getAttribute("data-action");
                    var messageId = Number(trigger.getAttribute("data-message-id") || 0);
                    if (!action || !messageId) return;

                    var targetMessage = allMessages.find(function (item) {
                        return Number(item.id || 0) === messageId;
                    });

                    if (action === "toggle-menu") {
                        event.preventDefault();
                        event.stopPropagation();
                        toggleMessageMenu(trigger);
                        return;
                    }

                    closeAllMessageMenus();

                    if (action === "reply") {
                        if (targetMessage) {
                            setReplyMessage(targetMessage);
                            if (messageInput) {
                                messageInput.focus();
                            }
                        }
                        return;
                    }

                    if (action === "react-like") {
                        toggleReaction(messageId, "like");
                        return;
                    }

                    if (action === "menu-remove") {
                        var canUnsend = targetMessage && Number(targetMessage.senderId || 0) === currentUserId && !Boolean(targetMessage.isDeletedForEveryone);
                        if (canUnsend) {
                            if (window.confirm("Bạn muốn gỡ tin nhắn này?")) {
                                unsendMessage(messageId);
                            }
                            return;
                        }

                        if (window.confirm("Gỡ tin nhắn này phía bạn?")) {
                            hideMessageForMe(messageId);
                        }
                        return;
                    }

                    if (action === "toggle-pin") {
                        togglePinnedMessage(messageId);
                        renderMessages(allMessages);
                        return;
                    }
                });

                panel.addEventListener("scroll", function () {
                    closeAllMessageMenus();
                    if (panel.scrollTop < 80) {
                        loadOlderMessages();
                    }
                });
            }

            if (conversationList) {
                conversationList.addEventListener("click", function (event) {
                    var itemLink = event.target.closest(".conversation-item-link");
                    if (itemLink && conversationList.contains(itemLink)) {
                        if (event.defaultPrevented) return;
                        if (event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                            return;
                        }

                        var item = itemLink.closest(".conversation-list-item");
                        var targetConversationId = Number(item && item.getAttribute("data-conversation-id") || 0);
                        if (targetConversationId > 0) {
                            event.preventDefault();
                        }
                        if (targetConversationId > 0 && targetConversationId !== conversationId) {
                            switchConversation(targetConversationId, true);
                        }
                        return;
                    }

                    var trigger = event.target.closest("[data-action]");
                    if (!trigger) return;

                    var action = trigger.getAttribute("data-action");
                    if (action === "toggle-conversation-menu") {
                        event.preventDefault();
                        event.stopPropagation();
                        toggleConversationMenu(trigger);
                        return;
                    }

                    if (action === "delete-conversation") {
                        event.preventDefault();
                        event.stopPropagation();
                        var targetConversationId = Number(trigger.getAttribute("data-conversation-id") || 0);
                        if (!targetConversationId) return;
                        openDeleteConversationConfirm(targetConversationId);
                    }
                });

                conversationList.addEventListener("scroll", function () {
                    closeConversationMenus();
                });
            }

            document.addEventListener("click", function (event) {
                if (!event.target.closest(".message-more-wrap")) {
                    closeAllMessageMenus();
                }

                if (!event.target.closest(".conversation-actions")) {
                    closeConversationMenus();
                }
            });

            if (shouldScroll) {
                scrollToBottom();
            }

            currentConversationMembers = normalizeMemberList(currentConversationMembers);
            loadPinnedMessagesFromStorage();
            setConversationDisplay(currentConversationName, currentConversationAvatar);
            setGroupConversationUI(isGroupConversation);
            setActiveConversationInList(conversationId);
            if (conversationIdInput) {
                conversationIdInput.value = String(conversationId || 0);
            }
            updateCreateGroupSubmitState();
            updateAddMemberSubmitState();
            setRightPanelVisible(true);
            initRealtime();
            loadLatestMessages(shouldScroll, true);
            toggleMessageSearchPanel(false);

            window.addEventListener("popstate", function () {
                var params = new URLSearchParams(window.location.search || "");
                var urlConversationId = Number(params.get("conversationId") || 0);
                if (!urlConversationId || urlConversationId === conversationId) {
                    return;
                }

                switchConversation(urlConversationId, false);
            });

            if (sendForm && messageInput && sendButton && conversationId > 0) {
                sendForm.addEventListener("submit", async function (event) {
                    event.preventDefault();

                    var text = messageInput.value.trim();
                    var hasFiles = attachmentInput && attachmentInput.files && attachmentInput.files.length > 0;
                    if (!text && !hasFiles && !selectedEditMessage) return;

                    sendButton.disabled = true;
                    try {
                        await sendTypingState(false);
                        if (typingStopTimer) {
                            clearTimeout(typingStopTimer);
                            typingStopTimer = null;
                        }

                        if (selectedEditMessage) {
                            if (hasFiles || !text) {
                                return;
                            }

                            var edited = await editMessage(selectedEditMessage.id, text);
                            if (!edited) {
                                return;
                            }

                            setEditMessage(null, false);
                            messageInput.value = "";
                            return;
                        }

                        var formData = new FormData(sendForm);
                        var response = await fetch(sendForm.action, {
                            method: "POST",
                            headers: {
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: formData,
                            credentials: "same-origin"
                        });
                        if (response.status === 401) {
                            window.location.href = "/Account/Login";
                            return;
                        }

                        if (!response.ok) {
                            return;
                        }

                        messageInput.value = "";
                        if (attachmentInput) {
                            attachmentInput.value = "";
                            renderAttachmentPreview();
                        }
                        setReplyMessage(null);
                        await loadLatestMessages(true, true);
                        await refreshConversationList();
                    } finally {
                        sendButton.disabled = false;
                        messageInput.focus();
                    }
                });

                messageInput.addEventListener("input", function () {
                    if (!conversationId) return;

                    var hasText = messageInput.value.trim().length > 0;
                    if (!hasText) {
                        sendTypingState(false);
                        if (typingStopTimer) {
                            clearTimeout(typingStopTimer);
                            typingStopTimer = null;
                        }
                        return;
                    }

                    sendTypingState(true);
                    if (typingStopTimer) {
                        clearTimeout(typingStopTimer);
                    }

                    typingStopTimer = setTimeout(function () {
                        sendTypingState(false);
                        typingStopTimer = null;
                    }, 1200);
                });

                messageInput.addEventListener("blur", function () {
                    sendTypingState(false);
                    if (typingStopTimer) {
                        clearTimeout(typingStopTimer);
                        typingStopTimer = null;
                    }
                });
            }

            var input = document.getElementById("conversationSearchInput");
            if (input) {
                var debounceTimer = null;
                input.addEventListener("input", function () {
                    if (debounceTimer) {
                        clearTimeout(debounceTimer);
                    }

                    debounceTimer = setTimeout(function () {
                        searchUsersRealtime(input.value);
                    }, 400);
                });

                if (input.value && input.value.trim()) {
                    searchUsersRealtime(input.value);
                }
            }

            if (openMessageSearchButton) {
                openMessageSearchButton.addEventListener("click", function () {
                    toggleMessageSearchPanel(true);
                    searchConversationMessages(messageSearchInput ? messageSearchInput.value : "");
                });
            }

            if (closeMessageSearchButton) {
                closeMessageSearchButton.addEventListener("click", function () {
                    toggleMessageSearchPanel(false);
                });
            }

            if (messageSearchInput) {
                var messageSearchDebounce = null;
                messageSearchInput.addEventListener("input", function () {
                    if (messageSearchDebounce) {
                        clearTimeout(messageSearchDebounce);
                    }

                    messageSearchDebounce = setTimeout(function () {
                        searchConversationMessages(messageSearchInput.value);
                    }, 280);
                });

                messageSearchInput.addEventListener("keydown", function (event) {
                    if (event.key === "Escape") {
                        toggleMessageSearchPanel(false);
                    }
                });
            }

            if (clearMessageSearchButton) {
                clearMessageSearchButton.addEventListener("click", function () {
                    if (!messageSearchInput) return;
                    messageSearchInput.value = "";
                    searchConversationMessages("");
                    messageSearchInput.focus();
                });
            }

            if (toggleRightPanelButton) {
                toggleRightPanelButton.addEventListener("click", function () {
                    setRightPanelVisible(!isRightPanelVisible);
                });
            }

            if (rightInfoPanel) {
                rightInfoPanel.addEventListener("click", function (event) {
                    var header = event.target.closest('[data-action="toggle-accordion"]');
                    if (!header) return;
                    var targetId = header.getAttribute("data-target") || "";
                    toggleAccordionBody(targetId);
                });
            }

            if (openPinnedMessagesButton) {
                openPinnedMessagesButton.addEventListener("click", function () {
                    renderPinnedMessagesModal();
                    setModalOpen(pinnedMessagesModal, true);
                });
            }

            if (closePinnedMessagesModalButton) {
                closePinnedMessagesModalButton.addEventListener("click", function () {
                    setModalOpen(pinnedMessagesModal, false);
                });
            }

            if (pinnedMessagesModal) {
                pinnedMessagesModal.addEventListener("click", function (event) {
                    if (event.target === pinnedMessagesModal) {
                        setModalOpen(pinnedMessagesModal, false);
                        return;
                    }

                    var item = event.target.closest('[data-action="open-pinned-message"]');
                    if (!item) return;
                    var messageId = Number(item.getAttribute("data-message-id") || 0);
                    if (!messageId) return;
                    setModalOpen(pinnedMessagesModal, false);
                    jumpToMessage(messageId);
                });
            }

            if (openRenameConversationButton) {
                openRenameConversationButton.addEventListener("click", function () {
                    openRenameConversationModal();
                });
            }

            if (closeRenameConversationModalButton) {
                closeRenameConversationModalButton.addEventListener("click", function () {
                    setModalOpen(renameConversationModal, false);
                });
            }

            if (cancelRenameConversationButton) {
                cancelRenameConversationButton.addEventListener("click", function () {
                    setModalOpen(renameConversationModal, false);
                });
            }

            if (renameConversationInput) {
                renameConversationInput.addEventListener("input", function () {
                    syncRenameCount();
                });
            }

            if (saveRenameConversationButton) {
                saveRenameConversationButton.addEventListener("click", async function () {
                    if (!renameConversationInput) return;
                    var nextName = renameConversationInput.value.trim();
                    if (!nextName) return;

                    saveRenameConversationButton.disabled = true;
                    try {
                        var ok = await updateConversationSettings({ name: nextName });
                        if (!ok) return;
                        setModalOpen(renameConversationModal, false);
                    } finally {
                        syncRenameCount();
                    }
                });
            }

            if (renameConversationModal) {
                renameConversationModal.addEventListener("click", function (event) {
                    if (event.target === renameConversationModal) {
                        setModalOpen(renameConversationModal, false);
                    }
                });
            }

            if (changeConversationImageButton && conversationImageInput) {
                changeConversationImageButton.addEventListener("click", function () {
                    conversationImageInput.click();
                });

                conversationImageInput.addEventListener("change", async function () {
                    var file = conversationImageInput.files && conversationImageInput.files[0];
                    if (!file) return;
                    await uploadConversationImage(file);
                    conversationImageInput.value = "";
                });
            }

            if (openAddMemberButton) {
                openAddMemberButton.addEventListener("click", function () {
                    resetAddMemberState();
                    setModalOpen(addMemberModal, true);
                    if (addMemberSearchInput) {
                        addMemberSearchInput.focus();
                    }
                });
            }

            if (closeAddMemberModalButton) {
                closeAddMemberModalButton.addEventListener("click", function () {
                    setModalOpen(addMemberModal, false);
                });
            }

            if (cancelAddMemberButton) {
                cancelAddMemberButton.addEventListener("click", function () {
                    setModalOpen(addMemberModal, false);
                });
            }

            if (addMemberModal) {
                addMemberModal.addEventListener("click", function (event) {
                    if (event.target === addMemberModal) {
                        setModalOpen(addMemberModal, false);
                    }
                });
            }

            if (addMemberSearchInput) {
                var addMemberDebounce = null;
                addMemberSearchInput.addEventListener("input", function () {
                    if (addMemberDebounce) {
                        clearTimeout(addMemberDebounce);
                    }
                    addMemberDebounce = setTimeout(function () {
                        searchUsersForAddMember(addMemberSearchInput.value);
                    }, 260);
                });
            }

            if (addMemberResults) {
                addMemberResults.addEventListener("click", function (event) {
                    var button = event.target.closest('[data-action="toggle-add-member"]');
                    if (!button) return;

                    var userId = Number(button.getAttribute("data-user-id") || 0);
                    if (!userId) return;

                    var key = String(userId);
                    if (selectedAddMemberMap[key]) {
                        delete selectedAddMemberMap[key];
                    } else {
                        selectedAddMemberMap[key] = {
                            userId: userId,
                            fullName: decodeHtmlEntities(button.getAttribute("data-user-name") || ""),
                            email: decodeHtmlEntities(button.getAttribute("data-user-email") || ""),
                            avatarUrl: decodeHtmlEntities(button.getAttribute("data-user-avatar") || "")
                        };
                    }

                    renderSelectedAddMembers();
                    updateAddMemberSubmitState();
                    if (addMemberSearchInput && addMemberSearchInput.value.trim()) {
                        searchUsersForAddMember(addMemberSearchInput.value);
                    }
                });
            }

            if (selectedAddMembers) {
                selectedAddMembers.addEventListener("click", function (event) {
                    var removeButton = event.target.closest('[data-action="remove-add-member"]');
                    if (!removeButton) return;
                    var userId = Number(removeButton.getAttribute("data-user-id") || 0);
                    if (!userId) return;
                    delete selectedAddMemberMap[String(userId)];
                    renderSelectedAddMembers();
                    updateAddMemberSubmitState();
                    if (addMemberSearchInput && addMemberSearchInput.value.trim()) {
                        searchUsersForAddMember(addMemberSearchInput.value);
                    }
                });
            }

            if (submitAddMemberButton) {
                submitAddMemberButton.addEventListener("click", function () {
                    submitAddMembers();
                });
            }

            if (closeDeleteConversationConfirmButton) {
                closeDeleteConversationConfirmButton.addEventListener("click", function () {
                    closeDeleteConversationConfirm();
                });
            }

            if (cancelDeleteConversationConfirmButton) {
                cancelDeleteConversationConfirmButton.addEventListener("click", function () {
                    closeDeleteConversationConfirm();
                });
            }

            if (confirmDeleteConversationButton) {
                confirmDeleteConversationButton.addEventListener("click", function () {
                    var targetConversationId = Number(pendingDeleteConversationId || 0);
                    if (!targetConversationId) return;
                    deleteConversationForEveryone(targetConversationId);
                });
            }

            if (deleteConversationConfirmModal) {
                deleteConversationConfirmModal.addEventListener("click", function (event) {
                    if (event.target === deleteConversationConfirmModal) {
                        closeDeleteConversationConfirm();
                    }
                });
            }

            if (openCreateGroupButton) {
                openCreateGroupButton.addEventListener("click", function () {
                    openCreateGroupModal();
                });
            }

            if (closeCreateGroupModalButton) {
                closeCreateGroupModalButton.addEventListener("click", function () {
                    closeCreateGroupModal();
                });
            }

            if (cancelCreateGroupButton) {
                cancelCreateGroupButton.addEventListener("click", function () {
                    closeCreateGroupModal();
                });
            }

            if (createGroupModal) {
                createGroupModal.addEventListener("click", function (event) {
                    if (event.target === createGroupModal) {
                        closeCreateGroupModal();
                    }
                });
            }

            if (createGroupSearchInput) {
                var groupSearchDebounce = null;
                createGroupSearchInput.addEventListener("input", function () {
                    if (groupSearchDebounce) {
                        clearTimeout(groupSearchDebounce);
                    }

                    groupSearchDebounce = setTimeout(function () {
                        searchUsersForCreateGroup(createGroupSearchInput.value);
                    }, 260);
                });

                createGroupSearchInput.addEventListener("keydown", function (event) {
                    if (event.key === "Escape") {
                        closeCreateGroupModal();
                    }
                });
            }

            if (createGroupUserResults) {
                createGroupUserResults.addEventListener("click", function (event) {
                    var button = event.target.closest('[data-action="toggle-group-member"]');
                    if (!button) return;
                    addOrRemoveGroupMemberFromButton(button);
                });
            }

            if (selectedGroupMembers) {
                selectedGroupMembers.addEventListener("click", function (event) {
                    var removeButton = event.target.closest('[data-action="remove-selected-member"]');
                    if (!removeButton) return;

                    var userId = Number(removeButton.getAttribute("data-user-id") || 0);
                    if (!userId) return;

                    delete selectedGroupMemberMap[String(userId)];
                    renderSelectedGroupMembers();
                    updateCreateGroupSubmitState();
                    if (createGroupSearchInput && createGroupSearchInput.value.trim()) {
                        searchUsersForCreateGroup(createGroupSearchInput.value);
                    }
                });
            }

            if (submitCreateGroupButton) {
                submitCreateGroupButton.addEventListener("click", function () {
                    submitCreateGroup();
                });
            }

            window.addEventListener("resize", function () {
                if (window.matchMedia("(max-width: 1200px)").matches) {
                    return;
                }

                setRightPanelVisible(isRightPanelVisible);
            });

            document.addEventListener("keydown", function (event) {
                if (event.key !== "Escape") return;
                if (deleteConversationConfirmModal && deleteConversationConfirmModal.classList.contains("open")) {
                    closeDeleteConversationConfirm();
                    return;
                }
                if (createGroupModal && createGroupModal.classList.contains("open")) {
                    closeCreateGroupModal();
                    return;
                }
                if (addMemberModal && addMemberModal.classList.contains("open")) {
                    setModalOpen(addMemberModal, false);
                    return;
                }
                if (renameConversationModal && renameConversationModal.classList.contains("open")) {
                    setModalOpen(renameConversationModal, false);
                    return;
                }
                if (pinnedMessagesModal && pinnedMessagesModal.classList.contains("open")) {
                    setModalOpen(pinnedMessagesModal, false);
                }
            });

            if (messageSearchResults) {
                messageSearchResults.addEventListener("click", function (event) {
                    var item = event.target.closest(".message-search-item");
                    if (!item) return;

                    var messageId = Number(item.getAttribute("data-message-id") || 0);
                    if (!messageId) return;
                    jumpToMessage(messageId);
                });
            }

            if (pickFilesButton && attachmentInput) {
                pickFilesButton.addEventListener("click", function () {
                    attachmentInput.click();
                });

                attachmentInput.addEventListener("change", function () {
                    renderAttachmentPreview();
                });
            }

            window.addEventListener("beforeunload", function () {
                if (realtimeSyncTimer) {
                    clearTimeout(realtimeSyncTimer);
                    realtimeSyncTimer = null;
                }
                if (conversationRefreshTimer) {
                    clearTimeout(conversationRefreshTimer);
                    conversationRefreshTimer = null;
                }
                if (!connection || connection.state !== signalR.HubConnectionState.Connected) return;
                sendTypingState(false);
                connection.invoke("LeaveConversation", conversationId);
            });
        })();
    </script>
</body>
</html>

